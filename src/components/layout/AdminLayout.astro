---
import "@/styles/global.css";

interface Props {
  lang?: string;
  title?: string;
  description?: string;
}

const lang = Astro.props.lang ?? "en";
const title = Astro.props.title ?? "Sora Ramen Admin";
const description = Astro.props.description ?? "Staff order management for Sora Ramen.";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fbff" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Sora Admin" />
    <link rel="manifest" href="/admin-manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  </head>
  <body class="admin-body">
    <slot />
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }

      window.__soraAdminInstallPrompt = null;
      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        window.__soraAdminInstallPrompt = event;
      });

      window.installSoraAdminApp = async () => {
        const promptEvent = window.__soraAdminInstallPrompt;
        if (!promptEvent) return { status: "manual" };
        promptEvent.prompt();
        const choice = await promptEvent.userChoice.catch(() => ({ outcome: "dismissed" }));
        window.__soraAdminInstallPrompt = null;
        return { status: choice.outcome === "accepted" ? "accepted" : "dismissed" };
      };
    </script>
  </body>
</html>

<style>
  :global(.admin-body) {
    min-height: 100vh;
    background: var(--admin-bg);
    color: var(--admin-text);
  }
</style>

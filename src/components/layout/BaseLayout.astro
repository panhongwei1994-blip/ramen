---
import "@/styles/global.css";
import { getContent, getLocaleUrls, getRestaurantSchema, normalizeLocale } from "@/data/site";

interface Props {
  lang?: string;
}

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
const localeUrls = getLocaleUrls(lang);
const siteUrl = Astro.site ?? new URL("https://ramen.hisora.cc");
const canonicalPath = lang === "en" ? "/" : `/${lang}`;
const canonical = new URL(canonicalPath, siteUrl).toString();
const socialImage = new URL("/ramen/hero-poster-768.jpg", siteUrl).toString();
const schema = getRestaurantSchema(siteUrl.toString(), lang);
---

<!doctype html>
<html lang={lang} data-brand={content.brand}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <title>{content.metaTitle}</title>
    <meta name="description" content={content.metaDescription} />
    <meta property="og:title" content={content.metaTitle} />
    <meta property="og:description" content={content.metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.metaTitle} />
    <meta name="twitter:description" content={content.metaDescription} />
    <meta name="theme-color" content="#120e0d" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={content.brand} />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-shell card">
        <a href={lang === "en" ? "/" : `/${lang}`} class="brand-mark">
          <img src="/ramen/logo-320.jpg" alt={`${content.brand} logo`} class="brand-logo" width="44" height="44" />
          <span>{content.brand}</span>
        </a>
        <div class="header-actions">
          <details class="locale-menu">
            <summary class="locale-trigger">
              <span>{lang.toUpperCase()}</span>
              <span class="locale-caret">▾</span>
            </summary>
            <div class="locale-popover">
              {localeUrls.map((item) => (
                <a
                  href={item.url}
                  class:list={["locale-option", { active: item.active }]}
                >
                  {item.locale.toUpperCase()}
                </a>
              ))}
            </div>
          </details>
          <button type="button" class="header-order" onclick={`window.dispatchEvent(new CustomEvent('open-cart'))`}>
            {content.cartNav}
          </button>
        </div>
      </div>
    </header>
    <slot />
    <div class="install-modal" id="install-modal" hidden>
      <div class="install-backdrop" data-install-close></div>
      <div class="install-dialog card" role="dialog" aria-modal="true" aria-labelledby="install-title">
        <button class="install-close" type="button" data-install-close aria-label="Close">×</button>
        <img src="/ramen/logo-320.jpg" alt={`${content.brand} logo`} class="install-logo" width="96" height="96" />
        <p class="eyebrow">{content.brand}</p>
        <div class="install-title-row">
          <span class="install-title-icon" aria-hidden="true">+</span>
          <h3 id="install-title">Add to your home screen</h3>
        </div>
        <p class="install-copy" id="install-copy"></p>
        <div class="install-steps" id="install-steps"></div>
        <button class="primary-button install-confirm" type="button" data-install-close>Close</button>
      </div>
    </div>
    <script is:inline>
      const brandName = document.documentElement.dataset.brand || "App";
      const isChinese = document.documentElement.lang === "zh";
      const installDismissedKey = "sumi-ramen-ios-install-dismissed";

      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }

      let deferredInstallPrompt = null;

      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
      });

      const isIosSafari = () => {
        const ua = window.navigator.userAgent;
        const isIOS = /iphone|ipad|ipod/i.test(ua);
        const isSafari = /safari/i.test(ua) && !/crios|fxios|edgios/i.test(ua);
        return isIOS && isSafari;
      };

      const isStandalone = () =>
        window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;

      const modal = document.getElementById("install-modal");
      const copyNode = document.getElementById("install-copy");
      const stepsNode = document.getElementById("install-steps");

      const showInstallModal = (variant) => {
        if (!(modal instanceof HTMLElement) || !(copyNode instanceof HTMLElement) || !(stepsNode instanceof HTMLElement)) return;

        const ios = variant === "ios";
        modal.dataset.variant = variant;
        const titleNode = document.getElementById("install-title");
        const confirmNode = document.querySelector(".install-confirm");
        if (titleNode) {
          titleNode.textContent = ios
            ? (isChinese ? `将 ${brandName} 添加到手机屏幕` : `Add ${brandName} to your Home Screen`)
            : (isChinese ? `安装 ${brandName}` : `Install ${brandName}`);
        }
        if (confirmNode instanceof HTMLButtonElement) {
          confirmNode.textContent = ios
            ? (isChinese ? "不再提醒" : "Do not remind me")
            : (isChinese ? "关闭" : "Close");
        }
        copyNode.textContent = ios
          ? (isChinese
            ? "点按浏览器里的分享按钮，在菜单中选择“添加到主屏幕”。不同浏览器的分享入口可能在底部、顶部或菜单内。"
            : `Tap the browser Share button, then choose Add to Home Screen. The share control may sit at the bottom, top, or inside the menu depending on your browser.`)
          : (isChinese
            ? `将 ${brandName} 添加到主屏幕，方便下次快速打开。`
            : `Install ${brandName} for faster access from your device home screen.`);
        stepsNode.innerHTML = ios
          ? `
            <div class="install-step"><span class="install-step-number">↗</span><p>${isChinese ? "点按浏览器中的“分享”或分享图标。" : "Tap Share or the share icon in your browser."}</p></div>
            <div class="install-step"><span class="install-step-number">+</span><p>${isChinese ? "在菜单中选择“添加到主屏幕”。" : "Choose Add to Home Screen from the menu."}</p></div>
          `
          : `
            <div class="install-step"><span class="install-step-number">≡</span><p>${isChinese ? "打开浏览器菜单。" : "Open your browser menu."}</p></div>
            <div class="install-step"><span class="install-step-number">+</span><p>${isChinese ? "选择“安装应用”或“添加到主屏幕”。" : "Choose Install App or Add to Home Screen."}</p></div>
          `;
        modal.hidden = false;
        document.documentElement.style.overflow = "hidden";
      };

      const closeInstallModal = () => {
        if (!(modal instanceof HTMLElement)) return;
        if (modal.dataset.variant === "ios") {
          try {
            window.localStorage.setItem(installDismissedKey, "true");
          } catch {
            // Ignore storage access issues.
          }
        }
        modal.hidden = true;
        document.documentElement.style.overflow = "";
      };

      const installApp = async () => {
        if (isStandalone()) return;

        if (deferredInstallPrompt) {
          deferredInstallPrompt.prompt();
          await deferredInstallPrompt.userChoice.catch(() => {});
          deferredInstallPrompt = null;
          return;
        }

        if (isIosSafari()) {
          showInstallModal("ios");
          return;
        }

        showInstallModal("generic");
      };

      document.addEventListener("click", (event) => {
        const trigger = event.target instanceof Element ? event.target.closest("[data-a2hs-trigger]") : null;
        if (!(trigger instanceof HTMLButtonElement)) return;
        event.preventDefault();
        void installApp();
      });

      document.addEventListener("click", (event) => {
        const closeTrigger = event.target instanceof Element ? event.target.closest("[data-install-close]") : null;
        if (!closeTrigger) return;
        event.preventDefault();
        closeInstallModal();
      });

      window.addEventListener("load", () => {
        if (!isIosSafari() || isStandalone()) return;
        try {
          if (window.localStorage.getItem(installDismissedKey) === "true") return;
        } catch {
          // Ignore storage access issues.
        }
        window.setTimeout(() => showInstallModal("ios"), 1800);
      });
    </script>
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    inset: 16px 16px auto;
    z-index: 30;
  }
  .header-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 999px;
    backdrop-filter: blur(18px);
    background:
      linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.022)),
      rgba(20,15,13,.76);
  }
  .brand-mark,
  .locale-trigger,
  .locale-option,
  .header-order {
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .brand-mark {
    display: flex;
    align-items: center;
    gap: 14px;
    white-space: nowrap;
    text-decoration: none;
    color: var(--gold-soft);
  }
  .brand-logo {
    height: 42px;
    width: 42px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(241,182,107,.24);
    box-shadow: 0 10px 24px rgba(195,75,45,.2);
  }
  .header-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .locale-menu,
  .locale-trigger {
    border-radius: 999px;
    color: rgba(246,239,230,.68);
  }
  .locale-menu {
    position: relative;
  }
  .locale-trigger {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
    cursor: pointer;
  }
  .locale-trigger::-webkit-details-marker {
    display: none;
  }
  .locale-caret {
    color: rgba(244,213,154,.82);
    font-size: 11px;
  }
  .locale-popover {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 88px;
    display: grid;
    gap: 6px;
    padding: 8px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,.08);
    background:
      linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03)),
      rgba(10,12,18,.96);
    box-shadow: 0 18px 48px rgba(0,0,0,.34);
  }
  .locale-option {
    padding: 10px 12px;
    border-radius: 14px;
    color: rgba(246,239,230,.78);
    text-align: center;
  }
  .locale-option.active,
  .locale-option:hover {
    background: rgba(212,165,74,.14);
    color: var(--gold-soft);
  }
  .header-order {
    border: 0;
    padding: 8px 13px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--gold), var(--gold-soft));
    color: #180d08;
    font-size: 11px;
    letter-spacing: .18em;
  }
  .install-modal[hidden] {
    display: none;
  }
  .install-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
  }
  .install-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 6, 10, .78);
    backdrop-filter: blur(12px);
  }
  .install-dialog {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(420px, calc(100vw - 24px));
    padding: 18px;
    text-align: center;
  }
  .install-modal[data-variant="ios"] .install-backdrop {
    background: rgba(15, 23, 42, .26);
    backdrop-filter: blur(2px);
  }
  .install-modal[data-variant="ios"] .install-dialog {
    top: auto;
    bottom: calc(16px + env(safe-area-inset-bottom));
    transform: translateX(-50%);
    width: min(520px, calc(100vw - 20px));
    padding: 12px 14px 12px;
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(36, 44, 60, .98), rgba(25, 31, 44, .98)),
      #1f2634;
    border: 1px solid rgba(255,255,255,.12);
    text-align: left;
    box-shadow: 0 24px 60px rgba(0,0,0,.42);
  }
  .install-modal[data-variant="ios"] .install-logo,
  .install-modal[data-variant="ios"] .eyebrow {
    display: none;
  }
  .install-modal[data-variant="ios"] .install-close {
    border: 0;
    background: transparent;
    color: rgba(235, 240, 248, .72);
    font-size: 20px;
  }
  .install-modal[data-variant="ios"] h3 {
    margin: 0;
    color: #f8fafc;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0;
    line-height: 1.22;
  }
  .install-modal[data-variant="ios"] .install-copy {
    margin: 6px 0 0;
    color: rgba(226, 232, 240, .82);
    font-size: 0.78rem;
    line-height: 1.4;
  }
  .install-modal[data-variant="ios"] .install-steps {
    gap: 4px;
    margin-top: 8px;
  }
  .install-modal[data-variant="ios"] .install-step {
    grid-template-columns: 22px 1fr;
    padding: 0;
    border: 0;
    background: transparent;
  }
  .install-modal[data-variant="ios"] .install-step-number {
    background: rgba(96, 165, 250, .16);
    color: #93c5fd;
    width: 18px;
    height: 18px;
    font-size: 9px;
  }
  .install-modal[data-variant="ios"] .install-step p {
    color: rgba(226, 232, 240, .9);
    font-size: 0.75rem;
    line-height: 1.34;
  }
  .install-modal[data-variant="ios"] .install-confirm {
    min-height: 40px;
    margin-top: 10px;
    border: 1px solid rgba(148, 163, 184, .28);
    border-radius: 12px;
    background: transparent;
    color: #f8fafc;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
  }
  .install-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 999px;
    background: rgba(255,255,255,.05);
    color: var(--text);
  }
  .install-logo {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    object-fit: cover;
    border: 1px solid rgba(212,165,74,.28);
    box-shadow: 0 10px 24px rgba(212,165,74,.2);
  }
  .install-dialog h3 {
    margin: 0;
    font-size: 1.18rem;
    line-height: 1.05;
  }
  .install-title-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }
  .install-title-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 8px;
    background: rgba(212,165,74,.14);
    color: var(--gold-soft);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 12px;
    font-weight: 700;
  }
  .install-copy {
    margin: 8px 0 0;
    color: var(--muted);
    line-height: 1.42;
    font-size: .84rem;
  }
  .install-steps {
    display: grid;
    gap: 6px;
    margin-top: 10px;
    text-align: left;
  }
  .install-step {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 10px;
    align-items: start;
    padding: 8px 10px;
    border-radius: 12px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
  }
  .install-step-number {
    display: inline-grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: rgba(212,165,74,.14);
    color: var(--gold-soft);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
  }
  .install-step p {
    margin: 2px 0 0;
    color: var(--text);
    line-height: 1.38;
    font-size: .8rem;
  }
  .install-confirm {
    width: 100%;
    margin-top: 10px;
    min-height: 40px;
    font-size: 11px;
    letter-spacing: .12em;
  }
  @media (max-width: 860px) {
    .header-shell {
      flex-direction: row;
      align-items: center;
      border-radius: 28px;
      padding: 10px 12px;
    }
    .header-actions {
      justify-content: flex-end;
      flex-wrap: nowrap;
      min-width: 0;
    }
    .locale-popover {
      right: auto;
      left: 0;
    }
    .brand-mark {
      font-size: 11px;
      letter-spacing: .18em;
    }
    .brand-logo {
      height: 38px;
      width: 38px;
      border-radius: 10px;
    }
    .locale-trigger,
    .header-order {
      white-space: nowrap;
    }
    .locale-trigger {
      padding: 8px 12px;
    }
    .header-order {
      padding: 8px 12px;
    }
    .install-dialog {
      width: calc(100vw - 16px);
      padding: 24px 18px 18px;
      top: auto;
      bottom: 8px;
      transform: translateX(-50%);
      border-radius: 24px;
    }
  }
</style>

---
import { getContent, normalizeLocale } from "@/data/site";

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
---

<section id="story" class="future-shell container">
  <!-- Section cleared to provide whitespace as requested -->
</section>

<style>
  .future-shell {
    display: grid;
    grid-template-columns: .92fr 1.08fr;
    gap: 24px;
    padding: 12px 0 84px;
  }
  .future-copy {
    align-self: start;
    position: sticky;
    top: 112px;
  }
  .future-copy .section-title {
    margin-top: 8px;
    max-width: 10ch;
  }
  .future-copy .section-copy {
    max-width: 34rem;
    margin-top: 14px;
  }
  .future-meta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .future-meta span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
    color: rgba(243,230,208,.72);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
  }
  .future-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .future-card {
    min-height: 188px;
    padding: 18px;
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,.08);
    background:
      radial-gradient(circle at top right, rgba(195,75,45,.16), transparent 34%),
      linear-gradient(180deg, rgba(255,245,232,.05), rgba(255,245,232,.02)),
      rgba(26,19,17,.88);
  }
  .future-index {
    display: inline-flex;
    margin-bottom: 18px;
    color: rgba(241,182,107,.92);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .22em;
  }
  .future-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    font-size: .96rem;
  }
  @media (max-width: 900px) {
    .future-shell {
      grid-template-columns: 1fr;
    }
    .future-copy {
      position: static;
    }
  }
  @media (max-width: 560px) {
    .future-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { getContent, getLocalizedProducts, normalizeLocale } from "@/data/site";

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
const products = getLocalizedProducts(lang);

const featuredIds = [
  "midnight-tonkotsu",
  "spicy-miso-burn",
  "crispy-gyoza",
  "yuzu-soda",
  "late-night-feast-for-two",
];

const featured = featuredIds.flatMap((id) => {
  const product = products.find((item) => item.id === id);
  return product ? [product] : [];
});

const [heroImage, ...secondaryImages] = featured;
---

<section id="gallery" class="gallery-shell container">
  <div class="gallery-copy">
    <div>
      <p class="eyebrow">{content.brand}</p>
      <h2 class="section-title gallery-title">{content.galleryTitle}</h2>
    </div>
    <p class="section-copy">{content.galleryBody}</p>
  </div>

  {heroImage && (
    <div class="gallery-grid">
      <article class="gallery-lead">
        <img src={heroImage.image} alt={heroImage.name} loading="lazy" />
        <div class="gallery-caption">
          <span class="gallery-kicker">{content.categories.signature}</span>
          <h3>{heroImage.name}</h3>
          <p>{heroImage.description}</p>
        </div>
      </article>

      <div class="gallery-rail">
        {secondaryImages.map((product) => (
          <article class="gallery-tile">
            <img src={product.image} alt={product.name} loading="lazy" />
            <div class="gallery-tile-copy">
              <span>{product.name}</span>
              <p>{product.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .gallery-shell {
    display: grid;
    gap: 22px;
    padding: 8px 0 36px;
  }
  .gallery-copy {
    display: grid;
    grid-template-columns: .8fr 1.2fr;
    gap: 24px;
    align-items: end;
  }
  .gallery-copy .section-title {
    max-width: 11ch;
    text-wrap: balance;
  }
  .gallery-copy .section-copy {
    max-width: 40rem;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: 1.12fr .88fr;
    gap: 16px;
  }
  .gallery-lead,
  .gallery-tile {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,.08);
    background:
      radial-gradient(circle at top right, rgba(195,75,45,.18), transparent 32%),
      rgba(24,18,16,.88);
  }
  .gallery-lead img,
  .gallery-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: linear-gradient(180deg, rgba(255,245,232,.03), rgba(255,245,232,.01));
  }
  .gallery-lead {
    min-height: 560px;
  }
  .gallery-caption,
  .gallery-tile-copy {
    position: absolute;
    inset: auto 0 0 0;
    padding: 18px 18px 20px;
    background: linear-gradient(180deg, rgba(12,9,8,0) 0%, rgba(12,9,8,.92) 72%);
  }
  .gallery-kicker {
    display: inline-flex;
    margin-bottom: 10px;
    color: rgba(241,182,107,.92);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: .2em;
    text-transform: uppercase;
  }
  .gallery-caption h3,
  .gallery-tile-copy span {
    display: block;
    margin: 0;
    font-size: 1.28rem;
    line-height: 1.05;
  }
  .gallery-caption p,
  .gallery-tile-copy p {
    margin: 8px 0 0;
    color: rgba(243,230,208,.74);
    line-height: 1.6;
    font-size: .95rem;
  }
  .gallery-rail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .gallery-tile {
    min-height: 272px;
  }
  @media (max-width: 900px) {
    .gallery-copy,
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .gallery-copy {
      gap: 14px;
    }
    .gallery-copy .gallery-title {
      width: 100%;
      max-width: none;
      font-size: clamp(1.6rem, 6.2vw, 2.05rem);
      line-height: 1.04;
      letter-spacing: -0.03em;
      overflow-wrap: normal;
      word-break: normal;
      hyphens: none;
    }
    .gallery-rail {
      grid-template-columns: 1fr;
    }
    .gallery-lead {
      min-height: 420px;
    }
    .gallery-tile {
      min-height: 240px;
    }
  }
</style>

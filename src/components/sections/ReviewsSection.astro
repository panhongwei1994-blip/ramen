---
import { getContent, normalizeLocale, reviews } from "@/data/site";

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
---

<section id="reviews" class="container reviews-shell">
  <div class="reviews-head">
    <div>
      <p class="eyebrow">Guest Notes</p>
      <h2>{content.reviewTitle}</h2>
    </div>
    <p class="section-copy">{content.reviewBody}</p>
  </div>

  <div class="reviews-grid">
    {reviews.map((review) => (
      <article class="review-card">
        <div class="review-avatar" aria-hidden="true">{review.name.slice(0, 1)}</div>
        <div>
          <div class="review-headline">
            <strong>{review.name}</strong>
            <span>★★★★★</span>
          </div>
          <p>{review.quote}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .reviews-shell {
    padding: 0 0 28px;
  }
  .reviews-head {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 24px;
    align-items: end;
    margin-bottom: 24px;
  }
  .reviews-head h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1;
    letter-spacing: -.04em;
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .review-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    padding: 18px;
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(195,75,45,.14), transparent 34%),
      linear-gradient(180deg, rgba(255,245,232,.05), rgba(255,245,232,.02)),
      rgba(25,18,16,.9);
    border: 1px solid rgba(255,255,255,.08);
  }
  .review-avatar {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(241,182,107,.22);
    background: rgba(241,182,107,.1);
    color: rgba(241,182,107,.94);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
  }
  .review-headline {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }
  .review-headline span {
    color: #f4d59a;
    letter-spacing: .2em;
  }
  .review-card p {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.62;
    font-size: .95rem;
  }
  @media (max-width: 900px) {
    .reviews-head,
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

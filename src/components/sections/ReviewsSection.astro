---
import { getContent, normalizeLocale, reviews } from "@/data/site";

const lang = normalizeLocale(Astro.props.lang);
const content = getContent(lang);
---

<section id="reviews" class="container reviews-shell">
  <div class="reviews-head">
    <div>
      <p class="eyebrow">Guest Notes</p>
      <h2>{content.reviewTitle}</h2>
    </div>
    <p class="section-copy">{content.reviewBody}</p>
  </div>

  <div class="reviews-grid">
    {reviews.map((review) => (
      <article class="review-card">
        <img src={review.avatar} alt={review.name} loading="lazy" />
        <div>
          <div class="review-headline">
            <strong>{review.name}</strong>
            <span>★★★★★</span>
          </div>
          <p>{review.quote}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .reviews-shell {
    padding: 0 0 28px;
  }
  .reviews-head {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 24px;
    align-items: end;
    margin-bottom: 24px;
  }
  .reviews-head h2 {
    margin: 0;
    font-size: clamp(2.1rem, 3.4vw, 3.6rem);
    line-height: .98;
    letter-spacing: -.04em;
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .review-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    padding: 20px;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(195,75,45,.14), transparent 34%),
      linear-gradient(180deg, rgba(255,245,232,.05), rgba(255,245,232,.02)),
      rgba(25,18,16,.9);
    border: 1px solid rgba(255,255,255,.08);
  }
  .review-card img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  .review-headline {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }
  .review-headline span {
    color: #f4d59a;
    letter-spacing: .2em;
  }
  .review-card p {
    margin: 10px 0 0;
    color: var(--muted);
    line-height: 1.75;
  }
  @media (max-width: 900px) {
    .reviews-head,
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

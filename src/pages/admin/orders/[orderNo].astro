---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getOrderByOrderNo, getPaymentByOrderId, getRuntimeEnv } from "@/lib/orders";

export const prerender = false;

const orderNo = Astro.params.orderNo ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;
const payment = order ? await getPaymentByOrderId(order.id, runtimeEnv) : null;

if (!order) {
  Astro.response.status = 404;
}

const format = (value: number) => formatPrice(value, "en");
const actions = [
  { label: "Accept", endpoint: "accept", method: "POST" },
  { label: "Start cooking", endpoint: "status", method: "POST", payload: { status: "cooking", message: "Merchant started cooking." } },
  { label: "Out for delivery", endpoint: "status", method: "POST", payload: { status: "delivering", message: "Order handed off for delivery." } },
  { label: "Complete", endpoint: "status", method: "POST", payload: { status: "completed", message: "Order marked as completed." } },
  { label: "Cancel", endpoint: "cancel", method: "POST" },
];

function statusLabel(value: string) {
  return value.replaceAll("_", " ");
}

function tone(value: string) {
  if (value === "paid_waiting_accept") return "urgent";
  if (value === "accepted" || value === "cooking" || value === "delivering") return "active";
  if (value === "completed") return "done";
  if (value === "cancelled" || value === "refunded") return "muted";
  return "neutral";
}
---

<BaseLayout lang="en">
  <section class="container admin-shell" data-order-no={order?.orderNo ?? ""}>
    <div class="page-head">
      <div class="page-copy">
        <p class="eyebrow">Merchant Order</p>
        <h1 class="section-title">{order ? order.orderNo : "Order not found"}</h1>
        <p class="section-copy">Critical status, payment, and fulfillment actions are surfaced first. Supporting details sit below.</p>
      </div>
      <a class="ghost-button back-button" href="/admin/orders">Back to order queue</a>
    </div>

    {order ? (
      <>
        <section class:list={["card hero-panel", tone(order.orderStatus)]}>
          <div class="hero-copy">
            <div class="hero-badges">
              <span class:list={["status-pill", tone(order.orderStatus)]}>{statusLabel(order.orderStatus)}</span>
              <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                {statusLabel(order.paymentStatus)}
              </span>
            </div>
            <h2>{order.customerName || "Guest checkout"}</h2>
            <p>{order.fulfillment === "delivery" ? "Delivery order" : "Pickup order"} · {order.items.length} items · {new Date(order.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</p>
          </div>
          <div class="hero-meta">
            <span class="metric-label">Total</span>
            <strong>{format(order.totalAmount)}</strong>
          </div>
        </section>

        <section class="action-panel">
          {actions.map((action) => (
            <button
              class:list={["ghost-button admin-action", "emphasis"]}
              type="button"
              data-endpoint={action.endpoint}
              data-method={action.method}
              data-payload={action.payload ? JSON.stringify(action.payload) : ""}
            >
              {action.label}
            </button>
          ))}
          <div class="notice" id="admin-notice"></div>
        </section>

        <section class="card admin-card wide-card">
          <h2>Items</h2>
          <div class="line-items">
            {order.items.map((item) => (
              <article class="line-item">
                <img src={item.imageUrl} alt={item.productName} />
                <div>
                  <div class="line-head">
                    <strong>{item.productName}</strong>
                    <strong>{format(item.subtotal)}</strong>
                  </div>
                  <p>{format(item.unitPrice)} each × {item.quantity}</p>
                  {item.addOns.length ? <p>{item.addOns.map((addOn) => addOn.label).join(" · ")}</p> : null}
                  {item.note ? <p>{item.note}</p> : null}
                </div>
              </article>
            ))}
          </div>
        </section>

        <div class="detail-grid">
          <section class="card admin-card">
            <h2>Order summary</h2>
            <div class="summary-grid">
              <div>
                <span class="summary-label">Customer</span>
                <strong>{order.customerName || "Collected at checkout"}</strong>
              </div>
              <div>
                <span class="summary-label">Phone</span>
                <strong>{order.phone || "Pending Stripe confirmation"}</strong>
              </div>
              <div>
                <span class="summary-label">Address</span>
                <strong>{order.address || (order.fulfillment === "pickup" ? "Pickup" : "Pending Stripe confirmation")}</strong>
              </div>
              <div>
                <span class="summary-label">Payment intent</span>
                <strong>{order.stripePaymentIntentId || "Pending"}</strong>
              </div>
            </div>
          </section>

          <section class="card admin-card">
            <h2>Payment</h2>
            <div class="mini-stack">
              <div class="mini-row">
                <span class="summary-label">Provider status</span>
                <strong>{payment?.status ?? "unpaid"}</strong>
              </div>
              <div class="mini-row">
                <span class="summary-label">Session id</span>
                <strong>{order.stripeCheckoutSessionId || "Not created"}</strong>
              </div>
              <div class="mini-row">
                <span class="summary-label">Paid at</span>
                <strong>{order.paidAt || "Awaiting confirmation"}</strong>
              </div>
            </div>
          </section>

          <section class="card admin-card wide-card">
            <h2>Timeline</h2>
            <div class="timeline">
              {order.timeline.map((event) => (
                <article class="timeline-item">
                  <strong>{event.message}</strong>
                  <span>{new Date(event.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</span>
                </article>
              ))}
            </div>
          </section>
        </div>
      </>
    ) : null}
  </section>
</BaseLayout>

<script is:inline>
  const buttons = document.querySelectorAll(".admin-action");
  const notice = document.getElementById("admin-notice");
  const orderNo = document.querySelector("[data-order-no]")?.getAttribute("data-order-no") || "";

  for (const button of buttons) {
    button.addEventListener("click", async () => {
      if (!(button instanceof HTMLButtonElement) || !orderNo) return;
      const endpoint = button.dataset.endpoint;
      const method = button.dataset.method || "POST";
      const rawPayload = button.dataset.payload;
      const payload = rawPayload ? JSON.parse(rawPayload) : undefined;

      if (notice) {
        notice.textContent = "Updating order...";
      }

      const response = await fetch(`/api/admin/orders/${orderNo}/${endpoint}`, {
        method,
        headers: {
          "Content-Type": "application/json",
        },
        body: payload ? JSON.stringify(payload) : undefined,
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        if (notice) {
          notice.textContent = data.error || "Request failed.";
        }
        return;
      }

      if (notice) {
        notice.textContent = "Order updated.";
      }
      window.location.reload();
    });
  }
</script>

<style>
  :global(body) {
    background:
      linear-gradient(180deg, #eef6ff 0%, #f8fbff 42%, #ffffff 100%);
    color: #12314b;
  }
  :global(.site-header .header-shell) {
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(247,251,255,.94)),
      rgba(255,255,255,.92);
    border-color: rgba(45,108,223,.12);
    box-shadow: 0 16px 40px rgba(16,78,157,.08);
  }
  :global(.site-header .brand-mark) {
    color: #174ea6;
  }
  :global(.site-header .locale-trigger),
  :global(.site-header .locale-option),
  :global(.site-header .header-order) {
    color: rgba(18,49,75,.72);
  }
  :global(.site-header .header-order) {
    border-color: rgba(45,108,223,.14);
    background: rgba(45,108,223,.06);
  }
  .admin-shell {
    padding: 140px 0 88px;
    color: #12314b;
  }
  .page-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: end;
    margin-bottom: 24px;
  }
  .page-copy {
    max-width: 48rem;
  }
  .page-copy .section-copy,
  .hero-copy p,
  .line-item p,
  .timeline-item span {
    color: rgba(18,49,75,.68);
  }
  .eyebrow {
    color: #2d6cdf;
  }
  .hero-panel {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    padding: 24px;
    margin-bottom: 16px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.08);
  }
  .hero-panel.urgent {
    background:
      linear-gradient(180deg, rgba(255,244,244,.98), rgba(255,250,250,.98)),
      #ffffff;
    border-color: rgba(207,69,72,.24);
  }
  .hero-panel.active {
    background:
      linear-gradient(180deg, rgba(248,251,255,.98), rgba(255,255,255,.98)),
      #ffffff;
    border-color: rgba(45,108,223,.22);
  }
  .hero-badges,
  .action-panel {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-badges {
    margin-bottom: 14px;
  }
  .hero-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.98;
  }
  .hero-meta {
    min-width: 180px;
    padding: 16px 18px;
    border-radius: 22px;
    border: 1px solid rgba(45,108,223,.14);
    background: rgba(45,108,223,.08);
  }
  .metric-label,
  .summary-label {
    display: block;
    margin-bottom: 8px;
    color: rgba(18,49,75,.56);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hero-meta strong {
    font-size: 1.5rem;
    color: #174ea6;
  }
  .back-button,
  .admin-action {
    min-height: 46px;
  }
  .back-button {
    background: #ffffff;
    border-color: rgba(45,108,223,.16);
    color: #174ea6;
  }
  .action-panel {
    margin-bottom: 18px;
    align-items: center;
  }
  .admin-action.emphasis {
    border-color: rgba(45,108,223,.24);
    background: rgba(45,108,223,.08);
    color: #174ea6;
  }
  .notice {
    min-height: 24px;
    color: rgba(18,49,75,.58);
    margin-left: auto;
  }
  .detail-grid {
    display: grid;
    grid-template-columns: 1.25fr .85fr;
    gap: 18px;
    align-items: start;
  }
  .admin-card {
    padding: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.07);
  }
  .wide-card {
    grid-column: 1 / -1;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .mini-stack {
    display: grid;
    gap: 16px;
  }
  .mini-row strong,
  .summary-grid strong {
    word-break: break-word;
  }
  .status-pill,
  .payment-pill {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(45,108,223,.12);
    color: #12314b;
  }
  .status-pill.urgent {
    background: rgba(207,69,72,.1);
    border-color: rgba(207,69,72,.2);
  }
  .status-pill.active {
    background: rgba(45,108,223,.1);
    border-color: rgba(45,108,223,.18);
  }
  .status-pill.done {
    background: rgba(77,168,126,.12);
    border-color: rgba(77,168,126,.24);
  }
  .status-pill.muted {
    opacity: 0.78;
  }
  .payment-pill.paid {
    background: rgba(77,168,126,.12);
    border-color: rgba(77,168,126,.24);
  }
  .payment-pill.unpaid {
    background: rgba(207,69,72,.1);
    border-color: rgba(207,69,72,.2);
  }
  .line-items,
  .timeline {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }
  .line-item,
  .timeline-item {
    display: grid;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
  }
  .line-item {
    grid-template-columns: 88px 1fr;
  }
  .line-item img {
    width: 88px;
    height: 88px;
    border-radius: 18px;
    object-fit: cover;
  }
  .line-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  .line-item p,
  .timeline-item span {
    margin: 6px 0 0;
  }
  h2 {
    margin: 0;
    font-size: 1.5rem;
  }
  @media (max-width: 960px) {
    .page-head,
    .hero-panel,
    .detail-grid {
      display: grid;
    }
    .sticky-card {
      position: static;
    }
  }
  @media (max-width: 720px) {
    .summary-grid {
      grid-template-columns: 1fr;
    }
    .line-item {
      grid-template-columns: 1fr;
    }
    .line-item img {
      width: 100%;
      max-width: 180px;
    }
    .notice {
      margin-left: 0;
      width: 100%;
    }
  }
</style>

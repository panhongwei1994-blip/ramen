---
import AdminHeader from "@/components/admin/AdminHeader.astro";
import AdminLayout from "@/components/layout/AdminLayout.astro";
import { formatPrice } from "@/data/site";
import { getOrderByOrderNo, getPaymentByOrderId, getRuntimeEnv, getOrderLogsFromD1 } from "@/lib/orders";
import { buildAdminHref, getAdminLangFromUrl, getAdminModeFromUrl } from "@/lib/admin-links";

export const prerender = false;

const uiLang = getAdminLangFromUrl(Astro.url);
const isZh = uiLang === "zh";
const adminMode = getAdminModeFromUrl(Astro.url);
const fromHistory = Astro.url.searchParams.get("history") === "1";
const orderNo = Astro.params.orderNo ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;
const payment = order ? await getPaymentByOrderId(order.id, runtimeEnv) : null;
const logs = order ? await getOrderLogsFromD1(order.id, runtimeEnv) : [];

// Reconcile logs with internal timeline (backwards compatibility)
const timeline = [...(order?.timeline || [])];
for (const log of logs) {
  if (!timeline.find((t) => t.id === log.id || (t.createdAt === log.createdAt && t.message === log.message))) {
    timeline.push({
      id: log.id,
      type: log.type as any,
      message: log.message,
      createdAt: log.createdAt,
      meta: JSON.parse(log.metaJson || "{}"),
    });
  }
}
timeline.sort((a, b) => b.createdAt.localeCompare(a.createdAt)); // Newest first

const ordersBackHref = buildAdminHref(fromHistory ? "/admin/orders/history" : "/admin/orders", Astro.url.searchParams, {
  lang: uiLang,
  mode: adminMode,
  viewAll: false,
  history: fromHistory,
});

if (!order) {
  Astro.response.status = 404;
}

const format = (value: number) => formatPrice(value, "en");
type DetailAction = {
  label: string;
  endpoint: string;
  method: "POST";
  payload?: {
    status: string;
    message: string;
  };
  danger?: boolean;
};

const copy = isZh
  ? {
      pageEyebrow: "订单详情",
      pageMissing: "订单不存在",
      pageCopy: "把关键状态、支付和出餐操作放在最前面，其他信息放在下面。",
      back: fromHistory ? "返回历史订单" : "返回订单队列",
      langEn: "EN",
      langZh: "中文",
      deliveryOrder: "外送订单",
      pickupOrder: "自取订单",
      itemCount: "件菜品",
      total: "总额",
      items: "菜品",
      summary: "订单摘要",
      customer: "客户",
      phone: "电话",
      address: "地址",
      paymentIntent: "支付意图",
      payment: "支付信息",
      providerStatus: "支付状态",
      sessionId: "会话 ID",
      paidAt: "支付时间",
      awaitingConfirmation: "等待确认",
      guest: "游客结账",
      collectedAtCheckout: "结账时填写",
      pendingStripe: "等待 Stripe 确认",
      pickup: "自取",
      notCreated: "未创建",
      timeline: "时间线",
      updating: "更新中...",
      updated: "订单已更新",
      requestFailed: "请求失败",
      navOrders: "订单队列",
      navProducts: "菜品管理",
      navSettings: "店铺设置",
      modeFront: "前台模式",
      modeKitchen: "后厨模式",
      actionAccept: "接单",
      actionCooking: "开始制作",
      actionDelivery: "标记备好",
      actionComplete: "完成",
      kitchenStart: "开始出餐",
      kitchenComplete: "完成出餐",
      actionCancel: "取消订单",
      confirmCancel: "确认取消这笔订单？",
    }
  : {
      pageEyebrow: "Merchant Order",
      pageMissing: "Order not found",
      pageCopy: "Critical status, payment, and fulfillment actions are surfaced first. Supporting details sit below.",
      back: fromHistory ? "Back to history" : "Back to order queue",
      langEn: "EN",
      langZh: "中文",
      deliveryOrder: "Delivery order",
      pickupOrder: "Pickup order",
      itemCount: "items",
      total: "Total",
      items: "Items",
      summary: "Order summary",
      customer: "Customer",
      phone: "Phone",
      address: "Address",
      paymentIntent: "Payment intent",
      payment: "Payment",
      providerStatus: "Provider status",
      sessionId: "Session id",
      paidAt: "Paid at",
      awaitingConfirmation: "Awaiting confirmation",
      guest: "Guest checkout",
      collectedAtCheckout: "Collected at checkout",
      pendingStripe: "Pending Stripe confirmation",
      pickup: "Pickup",
      notCreated: "Not created",
      timeline: "Timeline",
      updating: "Updating order...",
      updated: "Order updated.",
      requestFailed: "Request failed.",
      navOrders: "Orders",
      navProducts: "Products",
      navSettings: "Settings",
      modeFront: "Front mode",
      modeKitchen: "Kitchen mode",
      actionAccept: "Accept",
      actionCooking: "Start preparing",
      actionDelivery: "Mark ready",
      actionComplete: "Complete",
      kitchenStart: "Start prep",
      kitchenComplete: "Complete order",
      actionCancel: "Cancel order",
      confirmCancel: "Cancel this order?",
    };

function actionsForOrder(currentOrder: typeof order): DetailAction[] {
  if (!currentOrder) return [];
  switch (currentOrder.orderStatus) {
    case "paid_waiting_accept":
      return [
        adminMode === "kitchen"
          ? { label: copy.kitchenStart, endpoint: "status", method: "POST" as const, payload: { status: "cooking", message: "Kitchen started preparing the order." } }
          : { label: copy.actionAccept, endpoint: "accept", method: "POST" as const },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST" as const, danger: true },
      ];
    case "accepted":
      return [
        { label: adminMode === "kitchen" ? copy.kitchenStart : copy.actionCooking, endpoint: "status", method: "POST" as const, payload: { status: "cooking", message: "Kitchen started preparing the order." } },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST" as const, danger: true },
      ];
    case "cooking":
      return [
        {
          label: adminMode === "kitchen" ? copy.kitchenComplete : copy.actionDelivery,
          endpoint: "status",
          method: "POST" as const,
          payload: {
            status: adminMode === "kitchen" ? "completed" : "delivering",
            message: adminMode === "kitchen" ? "Kitchen completed the order." : "Order marked ready.",
          },
        },
      ];
    case "delivering":
      return [
        { label: copy.actionComplete, endpoint: "status", method: "POST" as const, payload: { status: "completed", message: "Order marked as completed." } },
      ];
    default:
      return [];
  }
}

const actions = actionsForOrder(order);

function statusLabel(value: string) {
  if (!isZh) {
    return ({
      paid_waiting_accept: adminMode === "kitchen" ? "Queued" : "New",
      accepted: adminMode === "kitchen" ? "Queued" : "New",
      cooking: adminMode === "kitchen" ? "In prep" : "Preparing",
      delivering: adminMode === "kitchen" ? "Finish" : "Ready",
      completed: "Completed",
      cancelled: "Cancelled",
      refunded: "Refunded",
      paid: "Paid",
      unpaid: "Unpaid",
      failed: "Failed",
    } as Record<string, string>)[value] ?? value.replaceAll("_", " ");
  }
  return ({
    pending_payment: "待支付",
    paid_waiting_accept: adminMode === "kitchen" ? "待出餐" : "新订单",
    accepted: adminMode === "kitchen" ? "待出餐" : "新订单",
    cooking: adminMode === "kitchen" ? "出餐中" : "制作中",
    delivering: adminMode === "kitchen" ? "待完成" : "已备好",
    completed: "已完成",
    cancelled: "已取消",
    refunded: "已退款",
    paid: "已支付",
    unpaid: "未支付",
    failed: "失败",
  } as Record<string, string>)[value] ?? value.replaceAll("_", " ");
}

function tone(value: string) {
  if (value === "paid_waiting_accept") return adminMode === "kitchen" ? "active" : "urgent";
  if (value === "accepted" || value === "cooking" || value === "delivering") return "active";
  if (value === "completed") return "done";
  if (value === "cancelled" || value === "refunded") return "muted";
  return "neutral";
}

function formatDate(value: string) {
  return new Date(value).toLocaleString(isZh ? "zh-CN" : "en-US", { dateStyle: "medium", timeStyle: "short" });
}
---

<AdminLayout lang={uiLang} title={order ? `${order.orderNo} | Sumi Ramen Admin` : "Order | Sumi Ramen Admin"}>
  <section class="container admin-shell" data-order-no={order?.orderNo ?? ""} data-ui-lang={uiLang}>
    <AdminHeader
      lang={uiLang}
      mode={adminMode}
      pathname={Astro.url.pathname}
      searchParams={Astro.url.searchParams}
      activeNav="orders"
      eyebrow={copy.pageEyebrow}
      title={order ? order.orderNo : copy.pageMissing}
      copy={copy.pageCopy}
      navLabels={{
        orders: copy.navOrders,
        products: copy.navProducts,
        settings: copy.navSettings,
      }}
      langLabels={{ en: copy.langEn, zh: copy.langZh }}
      modeLabels={{ front: copy.modeFront, kitchen: copy.modeKitchen }}
      compact
    >
      <a slot="actions" class="ghost-button back-button" href={ordersBackHref}>{copy.back}</a>
    </AdminHeader>

    {order ? (
      <>
        <section class:list={["card hero-panel", tone(order.orderStatus)]}>
          <div class="hero-copy">
            <div class="hero-badges">
              <span class:list={["status-pill", tone(order.orderStatus)]}>{statusLabel(order.orderStatus)}</span>
              <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                {statusLabel(order.paymentStatus)}
              </span>
            </div>
            <h2>{order.customerName || copy.guest}</h2>
            <p>{order.fulfillment === "delivery" ? copy.deliveryOrder : copy.pickupOrder} · {order.items.length} {copy.itemCount} · {formatDate(order.createdAt)}</p>
          </div>
          <div class="hero-meta">
            <span class="metric-label">{copy.total}</span>
            <strong>{format(order.totalAmount)}</strong>
          </div>
        </section>

        <section class="card admin-card wide-card items-priority-card">
          <h2>{copy.items}</h2>
          <div class="line-items">
            {order.items.map((item) => (
              <article class="line-item">
                <img src={item.imageUrl} alt={item.productName} />
                <div>
                  <div class="line-head">
                    <strong>{item.productName}</strong>
                    <strong>{format(item.subtotal)}</strong>
                  </div>
                  <p class="line-item-base">{isZh ? `${format(item.unitPrice)} /份 × ${item.quantity}` : `${format(item.unitPrice)} each × ${item.quantity}`}</p>
                  {item.addOns.length ? <p class="line-item-addon">{item.addOns.map((addOn) => addOn.label).join(" · ")}</p> : null}
                  {item.note ? <p class="line-item-note">{item.note}</p> : null}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="action-panel">
          {actions.map((action) => (
            <button
              class:list={["ghost-button admin-action", action.danger ? "danger" : "emphasis"]}
              type="button"
              data-endpoint={action.endpoint}
              data-method={action.method}
              data-payload={action.payload ? JSON.stringify(action.payload) : ""}
            >
              {action.label}
            </button>
          ))}
          <div class="notice" id="admin-notice"></div>
        </section>

        <div class="detail-grid">
          <section class="card admin-card">
            <h2>{copy.summary}</h2>
            <div class="summary-grid">
              <div>
                <span class="summary-label">{copy.customer}</span>
                <strong>{order.customerName || copy.collectedAtCheckout}</strong>
              </div>
              <div>
                <span class="summary-label">{copy.phone}</span>
                <strong>{order.phone || copy.pendingStripe}</strong>
              </div>
              <div>
                <span class="summary-label">{copy.address}</span>
                <strong>{order.address || (order.fulfillment === "pickup" ? copy.pickup : copy.pendingStripe)}</strong>
              </div>
              <div>
                <span class="summary-label">{copy.paymentIntent}</span>
                <strong>{order.stripePaymentIntentId || copy.awaitingConfirmation}</strong>
              </div>
            </div>
          </section>

          <section class="card admin-card">
            <h2>{copy.payment}</h2>
            <div class="mini-stack">
              <div class="mini-row">
                <span class="summary-label">{copy.providerStatus}</span>
                <strong>{statusLabel(payment?.status ?? "unpaid")}</strong>
              </div>
              <div class="mini-row">
                <span class="summary-label">{copy.sessionId}</span>
                <strong>{order.stripeCheckoutSessionId || copy.notCreated}</strong>
              </div>
              <div class="mini-row">
                <span class="summary-label">{copy.paidAt}</span>
                <strong>{order.paidAt || copy.awaitingConfirmation}</strong>
              </div>
            </div>
          </section>

          <section class="card admin-card wide-card">
            <h2>{copy.timeline}</h2>
            <div class="timeline">
              {timeline.map((event) => (
                <article class="timeline-item">
                  <strong>{event.message}</strong>
                  <span>{formatDate(event.createdAt)}</span>
                </article>
              ))}
            </div>
          </section>
        </div>
      </>
    ) : null}

    <script
      is:inline
      type="application/json"
      id="admin-order-detail-copy"
      set:html={JSON.stringify({
        updating: copy.updating,
        updated: copy.updated,
        requestFailed: copy.requestFailed,
        confirmCancel: copy.confirmCancel,
      })}
    />

    <script is:inline>
      const notice = document.getElementById("admin-notice");
      const orderNo = document.querySelector("[data-order-no]")?.getAttribute("data-order-no") || "";
      const copyNode = document.getElementById("admin-order-detail-copy");
      const copy = JSON.parse(copyNode?.textContent || "{}");

      document.addEventListener("click", async (event) => {
        const target = event.target instanceof Element ? event.target.closest(".admin-action") : null;
        if (!(target instanceof HTMLButtonElement) || !orderNo) return;

        const endpoint = target.dataset.endpoint;
        const method = target.dataset.method || "POST";
        const rawPayload = target.dataset.payload;
        const payload = rawPayload ? JSON.parse(rawPayload) : undefined;

        if (endpoint === "cancel" && !window.confirm(copy.confirmCancel || "Cancel this order?")) {
          return;
        }

        if (notice) {
          notice.textContent = copy.updating;
        }

        const response = await fetch(`/api/admin/orders/${orderNo}/${endpoint}`, {
          method,
          headers: {
            "Content-Type": "application/json",
          },
          body: payload ? JSON.stringify(payload) : undefined,
        });

        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          if (notice) {
            notice.textContent = data.error || copy.requestFailed;
          }
          return;
        }

        if (notice) {
          notice.textContent = copy.updated;
        }
        window.location.reload();
      });
    </script>
  </section>
</AdminLayout>

<style>
  .admin-shell {
    padding: 32px 0 88px;
    color: #12314b;
  }
  .hero-copy p,
  .line-item p,
  .timeline-item span {
    color: var(--admin-muted);
  }
  .eyebrow {
    color: var(--admin-gold);
    font-weight: 800;
  }
  .hero-panel {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
    padding: 24px;
    margin-bottom: 16px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.08);
  }
  .hero-panel.urgent {
    background:
      linear-gradient(180deg, rgba(255,244,244,.98), rgba(255,250,250,.98)),
      #ffffff;
    border-color: rgba(207,69,72,.24);
  }
  .hero-panel.active {
    background:
      linear-gradient(180deg, rgba(248,251,255,.98), rgba(255,255,255,.98)),
      #ffffff;
    border-color: rgba(45,108,223,.22);
  }
  .hero-badges,
  .action-panel {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-badges {
    margin-bottom: 14px;
  }
  .hero-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.98;
  }
  .hero-meta {
    min-width: 180px;
    padding: 16px 18px;
    border-radius: 22px;
    border: 1px solid rgba(45,108,223,.14);
    background: rgba(45,108,223,.08);
  }
  .metric-label,
  .summary-label {
    display: block;
    margin-bottom: 8px;
    color: var(--admin-muted);
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .hero-meta strong {
    font-size: 1.5rem;
    color: var(--admin-accent);
    font-weight: 800;
  }
  .back-button,
  .admin-action {
    min-height: 46px;
  }
  .back-button {
    background: #ffffff;
    border-color: rgba(45,108,223,.16);
    color: #174ea6;
  }
  .action-panel {
    margin-bottom: 18px;
    align-items: center;
  }
  .admin-action.emphasis {
    border-color: rgba(45,108,223,.24);
    background: rgba(45,108,223,.08);
    color: #174ea6;
  }
  .admin-action.danger {
    border-color: rgba(207,69,72,.18);
    background: rgba(207,69,72,.08);
    color: #b42318;
  }
  .notice {
    min-height: 24px;
    color: rgba(18,49,75,.58);
    margin-left: auto;
  }
  .detail-grid {
    display: grid;
    grid-template-columns: 1.25fr .85fr;
    gap: 18px;
    align-items: start;
  }
  .admin-card {
    padding: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.07);
  }
  .wide-card {
    grid-column: 1 / -1;
  }
  .items-priority-card {
    margin-bottom: 16px;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .mini-stack {
    display: grid;
    gap: 16px;
  }
  .mini-row strong,
  .summary-grid strong {
    word-break: break-word;
  }
  .status-pill,
  .payment-pill {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(45,108,223,.12);
    color: #12314b;
  }
  .status-pill.urgent {
    background: rgba(207,69,72,.1);
    border-color: rgba(207,69,72,.2);
  }
  .status-pill.active {
    background: rgba(45,108,223,.1);
    border-color: rgba(45,108,223,.18);
  }
  .status-pill.done {
    background: rgba(77,168,126,.12);
    border-color: rgba(77,168,126,.24);
  }
  .status-pill.muted {
    opacity: 0.78;
  }
  .payment-pill.paid {
    background: rgba(77,168,126,.12);
    border-color: rgba(77,168,126,.24);
  }
  .payment-pill.unpaid {
    background: rgba(207,69,72,.1);
    border-color: rgba(207,69,72,.2);
  }
  .line-items,
  .timeline {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }
  .line-item,
  .timeline-item {
    display: grid;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
  }
  .line-item {
    grid-template-columns: 88px 1fr;
  }
  .line-item img {
    width: 88px;
    height: 88px;
    border-radius: 18px;
    object-fit: cover;
  }
  .line-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  .line-item p,
  .timeline-item span {
    margin: 6px 0 0;
  }
  .line-item-base {
    color: rgba(18,49,75,.68);
  }
  .line-item-addon {
    display: inline-flex;
    width: fit-content;
    margin-top: 10px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(45,108,223,.1);
    color: #174ea6;
    font-weight: 700;
    line-height: 1.5;
  }
  .line-item-note {
    color: rgba(18,49,75,.82);
  }
  h2 {
    margin: 0;
    font-size: 1.5rem;
  }
  @media (max-width: 960px) {
    .hero-panel,
    .detail-grid {
      display: grid;
    }
  }
  @media (max-width: 720px) {
    .summary-grid {
      grid-template-columns: 1fr;
    }
    .line-item {
      grid-template-columns: 1fr;
    }
    .line-item img {
      width: 100%;
      max-width: 180px;
    }
    .notice {
      margin-left: 0;
      width: 100%;
    }
  }
</style>

---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getOrderByOrderNo, getPaymentByOrderId, getRuntimeEnv } from "@/lib/orders";

export const prerender = false;

const orderNo = Astro.params.orderNo ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;
const payment = order ? await getPaymentByOrderId(order.id, runtimeEnv) : null;

if (!order) {
  Astro.response.status = 404;
}

const format = (value: number) => formatPrice(value, "en");
const actions = [
  { label: "Accept", endpoint: "accept", method: "POST" },
  { label: "Start cooking", endpoint: "status", method: "POST", payload: { status: "cooking", message: "Merchant started cooking." } },
  { label: "Out for delivery", endpoint: "status", method: "POST", payload: { status: "delivering", message: "Order handed off for delivery." } },
  { label: "Complete", endpoint: "status", method: "POST", payload: { status: "completed", message: "Order marked as completed." } },
  { label: "Cancel", endpoint: "cancel", method: "POST" },
  { label: "Refund", endpoint: "status", method: "POST", payload: { status: "refunded", message: "Merchant marked order as refunded." } },
];
---

<BaseLayout lang="en">
  <section class="container admin-shell" data-order-no={order?.orderNo ?? ""}>
    <div class="page-copy">
      <p class="eyebrow">Merchant Order</p>
      <h1 class="section-title">{order ? order.orderNo : "Order not found"}</h1>
      <p class="section-copy">Server-side order state, payment state, and lifecycle log in one place.</p>
      <div class="page-actions">
        <a class="ghost-button back-button" href="/admin/orders">Back to order queue</a>
      </div>
    </div>

    {order ? (
      <div class="admin-grid">
        <section class="card admin-card">
          <div class="summary-grid">
            <div>
              <span class="summary-label">Order status</span>
              <strong>{order.orderStatus.replaceAll("_", " ")}</strong>
            </div>
            <div>
              <span class="summary-label">Payment status</span>
              <strong>{order.paymentStatus.replaceAll("_", " ")}</strong>
            </div>
            <div>
              <span class="summary-label">Customer</span>
              <strong>{order.customerName || "Collected at checkout"}</strong>
            </div>
            <div>
              <span class="summary-label">Phone</span>
              <strong>{order.phone || "Pending Stripe confirmation"}</strong>
            </div>
            <div>
              <span class="summary-label">Address</span>
              <strong>{order.address || (order.fulfillment === "pickup" ? "Pickup" : "Pending Stripe confirmation")}</strong>
            </div>
            <div>
              <span class="summary-label">Total</span>
              <strong>{format(order.totalAmount)}</strong>
            </div>
          </div>

          <div class="actions">
            {actions.map((action) => (
              <button
                class="ghost-button admin-action"
                type="button"
                data-endpoint={action.endpoint}
                data-method={action.method}
                data-payload={action.payload ? JSON.stringify(action.payload) : ""}
              >
                {action.label}
              </button>
            ))}
          </div>

          <div class="notice" id="admin-notice"></div>
        </section>

        <section class="card admin-card">
          <h2>Items</h2>
          <div class="line-items">
            {order.items.map((item) => (
              <article class="line-item">
                <img src={item.imageUrl} alt={item.productName} />
                <div>
                  <div class="line-head">
                    <strong>{item.productName}</strong>
                    <strong>{format(item.subtotal)}</strong>
                  </div>
                  <p>{format(item.unitPrice)} each × {item.quantity}</p>
                  {item.addOns.length ? <p>{item.addOns.map((addOn) => addOn.label).join(" · ")}</p> : null}
                  {item.note ? <p>{item.note}</p> : null}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="card admin-card">
          <h2>Payment</h2>
          <div class="summary-grid">
            <div>
              <span class="summary-label">Session id</span>
              <strong>{order.stripeCheckoutSessionId || "Not created"}</strong>
            </div>
            <div>
              <span class="summary-label">Payment intent</span>
              <strong>{order.stripePaymentIntentId || "Pending"}</strong>
            </div>
            <div>
              <span class="summary-label">Provider status</span>
              <strong>{payment?.status ?? "unpaid"}</strong>
            </div>
          </div>
        </section>

        <section class="card admin-card">
          <h2>Timeline</h2>
          <div class="timeline">
            {order.timeline.map((event) => (
              <article class="timeline-item">
                <strong>{event.message}</strong>
                <span>{new Date(event.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</span>
              </article>
            ))}
          </div>
        </section>
      </div>
    ) : null}
  </section>
</BaseLayout>

<script is:inline>
  const buttons = document.querySelectorAll(".admin-action");
  const notice = document.getElementById("admin-notice");
  const orderNo = document.querySelector("[data-order-no]")?.getAttribute("data-order-no") || "";

  for (const button of buttons) {
    button.addEventListener("click", async () => {
      if (!(button instanceof HTMLButtonElement) || !orderNo) return;
      const endpoint = button.dataset.endpoint;
      const method = button.dataset.method || "POST";
      const rawPayload = button.dataset.payload;
      const payload = rawPayload ? JSON.parse(rawPayload) : undefined;

      notice.textContent = "Updating order...";
      const response = await fetch(`/api/admin/orders/${orderNo}/${endpoint}`, {
        method,
        headers: {
          "Content-Type": "application/json",
        },
        body: payload ? JSON.stringify(payload) : undefined,
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        notice.textContent = data.error || "Request failed.";
        return;
      }

      notice.textContent = "Order updated.";
      window.location.reload();
    });
  }
</script>

<style>
  .admin-shell {
    padding: 140px 0 80px;
  }
  .page-copy {
    max-width: 760px;
    margin-bottom: 28px;
  }
  .page-actions {
    margin-top: 18px;
  }
  .back-button {
    min-height: 46px;
  }
  .admin-grid {
    display: grid;
    gap: 20px;
  }
  .admin-card {
    padding: 24px;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }
  .summary-label {
    display: block;
    margin-bottom: 6px;
    color: var(--muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .admin-action {
    min-height: 46px;
  }
  .notice {
    min-height: 24px;
    margin-top: 14px;
    color: var(--muted);
  }
  .line-items,
  .timeline {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }
  .line-item,
  .timeline-item {
    display: grid;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
  }
  .line-item {
    grid-template-columns: 88px 1fr;
  }
  .line-item img {
    width: 88px;
    height: 88px;
    border-radius: 18px;
    object-fit: cover;
  }
  .line-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  .line-item p,
  .timeline-item span {
    margin: 6px 0 0;
    color: var(--muted);
  }
  h2 {
    margin: 0;
  }
  @media (max-width: 720px) {
    .line-item {
      grid-template-columns: 1fr;
    }
    .line-item img {
      width: 100%;
      max-width: 180px;
    }
  }
</style>

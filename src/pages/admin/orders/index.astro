---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getRuntimeEnv, hasPersistentOrderStore, listOrders } from "@/lib/orders";

export const prerender = false;

const runtimeEnv = getRuntimeEnv(Astro.locals);
const orders = await listOrders(runtimeEnv);
const hasPersistentStore = hasPersistentOrderStore(runtimeEnv);
const format = (value: number) => formatPrice(value, "en");
---

<BaseLayout lang="en">
  <section class="container admin-shell">
    <div class="page-copy">
      <p class="eyebrow">Merchant Orders</p>
      <h1 class="section-title">Live order queue</h1>
      <p class="section-copy">Minimal merchant view over the persisted order records.</p>
    </div>

    {!hasPersistentStore ? (
      <div class="storage-warning card">
        This deployment is running without the <strong>ORDERS</strong> KV binding. Orders will not persist across requests, so the admin page can appear empty after checkout. For this MVP you do not need a full database yet, but you do need a Cloudflare KV namespace bound as <strong>ORDERS</strong>.
      </div>
    ) : null}

    <div class="card table-card">
      <div class="table-head table-row">
        <span>Order</span>
        <span>Status</span>
        <span>Payment</span>
        <span>Total</span>
        <span>Created</span>
      </div>
      {orders.length ? (
        orders.map((order) => (
          <a class="table-row" href={`/admin/orders/${order.orderNo}`}>
            <span>{order.orderNo}</span>
            <span>{order.orderStatus.replaceAll("_", " ")}</span>
            <span>{order.paymentStatus.replaceAll("_", " ")}</span>
            <span>{format(order.totalAmount)}</span>
            <span>{new Date(order.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</span>
          </a>
        ))
      ) : (
        <div class="table-empty">
          {hasPersistentStore ? "No orders yet." : "No orders visible because persistent storage is not bound on this deployment."}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .admin-shell {
    padding: 140px 0 80px;
  }
  .page-copy {
    max-width: 760px;
    margin-bottom: 28px;
  }
  .storage-warning {
    margin-bottom: 20px;
    padding: 18px 20px;
    color: var(--text);
    line-height: 1.7;
    border-color: rgba(241, 182, 107, 0.25);
    background:
      linear-gradient(180deg, rgba(241, 182, 107, 0.08), rgba(241, 182, 107, 0.04)),
      var(--panel);
  }
  .table-card {
    overflow: hidden;
  }
  .table-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr .8fr 1.2fr;
    gap: 12px;
    padding: 18px 20px;
    border-top: 1px solid var(--line);
  }
  .table-head {
    border-top: 0;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
  }
  a.table-row:hover {
    background: rgba(255, 245, 232, 0.03);
  }
  .table-empty {
    padding: 24px 20px;
    color: var(--muted);
  }
  @media (max-width: 900px) {
    .table-row {
      grid-template-columns: 1fr;
    }
    .table-head {
      display: none;
    }
  }
</style>

---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getRuntimeEnv, hasPersistentOrderStore, listOrders, type OrderRecord } from "@/lib/orders";

export const prerender = false;

const uiLang = Astro.url.searchParams.get("ui") === "zh" ? "zh" : "en";
const isZh = uiLang === "zh";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const orders = await listOrders(runtimeEnv);
const hasPersistentStore = hasPersistentOrderStore(runtimeEnv);
const format = (value: number) => formatPrice(value, "en");
const makeLangHref = (lang: "en" | "zh") => {
  const params = new URLSearchParams(Astro.url.searchParams);
  if (lang === "zh") params.set("ui", "zh");
  else params.delete("ui");
  const query = params.toString();
  return query ? `${Astro.url.pathname}?${query}` : Astro.url.pathname;
};
const copy = isZh
  ? {
      pageEyebrow: "后台订单",
      pageTitle: "订单",
      pageCopy: "给员工看的亮色队列界面，处理中和已完成订单分开展示。",
      langEn: "EN",
      langZh: "中文",
      alertButton: "开启通知",
      alertOff: "通知关闭",
      alertOn: "通知已开启",
      alertFailed: "通知轮询失败",
      alertNew: "新订单",
      storageWarning: "当前部署没有持久化订单存储。请绑定 D1 的 DB，或保留旧的 ORDERS KV，否则结账后后台队列可能为空。",
      liveQueue: "实时队列",
      processing: "处理中",
      orders: "单",
      noProcessing: "当前没有处理中订单。",
      history: "历史订单",
      completed: "已完成",
      noCompleted: "还没有已完成订单。",
      closed: "关闭订单",
      cancelledRefunded: "取消 / 退款",
      guest: "游客结账",
      delivery: "外送",
      pickup: "自取",
      moreItems: "更多菜品",
      viewDetails: "查看详情",
      updateError: "更新订单失败。",
      updating: "更新中...",
      notifyTitle: "新订单来了",
      actionAccept: "接单",
      actionCancel: "取消",
      actionCooking: "开始出餐",
      actionDelivery: "开始配送",
      actionComplete: "完成",
    }
  : {
      pageEyebrow: "Merchant Orders",
      pageTitle: "Orders",
      pageCopy: "Bright, simple queue view for staff. Processing orders are separated from completed history.",
      langEn: "EN",
      langZh: "中文",
      alertButton: "Enable order alerts",
      alertOff: "Alerts off",
      alertOn: "Alerts on",
      alertFailed: "Alert polling failed",
      alertNew: "New order",
      storageWarning: "This deployment is running without persistent order storage. Bind a D1 database as DB or keep the legacy ORDERS KV binding enabled, otherwise the admin queue can look empty after checkout.",
      liveQueue: "Live queue",
      processing: "Processing",
      orders: "orders",
      noProcessing: "No processing orders.",
      history: "History",
      completed: "Completed",
      noCompleted: "No completed orders yet.",
      closed: "Closed",
      cancelledRefunded: "Cancelled / Refunded",
      guest: "Guest checkout",
      delivery: "delivery",
      pickup: "pickup",
      moreItems: "more items",
      viewDetails: "View details",
      updateError: "Unable to update order.",
      updating: "Updating...",
      notifyTitle: "New order received",
      actionAccept: "Accept",
      actionCancel: "Cancel",
      actionCooking: "Start cooking",
      actionDelivery: "Out for delivery",
      actionComplete: "Complete",
    };

const processingStatuses = new Set(["pending_payment", "paid_waiting_accept", "accepted", "cooking", "delivering"]);
const completedStatuses = new Set(["completed"]);
const closedStatuses = new Set(["cancelled", "refunded"]);

const processingOrders = orders.filter((order) => processingStatuses.has(order.orderStatus));
const completedOrders = orders.filter((order) => completedStatuses.has(order.orderStatus));
const closedOrders = orders.filter((order) => closedStatuses.has(order.orderStatus));

type QueueAction = {
  label: string;
  endpoint: string;
  method: "POST";
  payload?: {
    status: string;
    message: string;
  };
  tone?: "danger";
};

function statusLabel(value: string) {
  if (!isZh) return value.replaceAll("_", " ");
  return ({
    pending_payment: "待支付",
    paid_waiting_accept: "待接单",
    accepted: "已接单",
    cooking: "制作中",
    delivering: "配送中",
    completed: "已完成",
    cancelled: "已取消",
    refunded: "已退款",
    paid: "已支付",
    unpaid: "未支付",
    failed: "失败",
    refunded_payment: "已退款",
  } as Record<string, string>)[value] ?? value.replaceAll("_", " ");
}

function itemCountLabel(count: number) {
  return isZh ? `${count} 件菜品` : `${count} items`;
}

function fulfillmentLabel(value: OrderRecord["fulfillment"]) {
  if (value === "delivery") return copy.delivery;
  return copy.pickup;
}

function formatDate(value: string) {
  return new Date(value).toLocaleString(isZh ? "zh-CN" : "en-US", { dateStyle: "medium", timeStyle: "short" });
}

function formatPreviewQuantity(quantity: number, subtotal: number) {
  return isZh ? `${quantity} 份 · ${format(subtotal)}` : `${quantity} × ${format(subtotal)}`;
}

function orderTone(order: OrderRecord) {
  if (order.orderStatus === "pending_payment" || order.orderStatus === "paid_waiting_accept") return "urgent";
  if (order.orderStatus === "accepted" || order.orderStatus === "cooking" || order.orderStatus === "delivering") return "active";
  if (order.orderStatus === "completed") return "done";
  if (order.orderStatus === "cancelled" || order.orderStatus === "refunded") return "muted";
  return "neutral";
}

function queueActions(order: OrderRecord): QueueAction[] {
  switch (order.orderStatus) {
    case "paid_waiting_accept":
      return [
        { label: copy.actionAccept, endpoint: "accept", method: "POST" },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST", tone: "danger" },
      ];
    case "accepted":
      return [
        { label: copy.actionCooking, endpoint: "status", method: "POST", payload: { status: "cooking", message: "Merchant started cooking." } },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST", tone: "danger" },
      ];
    case "cooking":
      return [
        { label: copy.actionDelivery, endpoint: "status", method: "POST", payload: { status: "delivering", message: "Order handed off for delivery." } },
      ];
    case "delivering":
      return [
        { label: copy.actionComplete, endpoint: "status", method: "POST", payload: { status: "completed", message: "Order marked as completed." } },
      ];
    default:
      return [];
  }
}
---

<BaseLayout lang={uiLang}>
  <section class="container admin-shell" data-ui-lang={uiLang}>
    <div class="page-copy">
      <div>
        <p class="eyebrow admin-eyebrow">{copy.pageEyebrow}</p>
        <h1 class="section-title">{copy.pageTitle}</h1>
        <p class="section-copy">{copy.pageCopy}</p>
      </div>
      <div class="alert-actions">
        <div class="admin-lang-switch">
          <a class:list={["lang-button", { active: uiLang === "en" }]} href={makeLangHref("en")}>{copy.langEn}</a>
          <a class:list={["lang-button", { active: uiLang === "zh" }]} href={makeLangHref("zh")}>{copy.langZh}</a>
        </div>
        <button class="ghost-button alert-toggle" id="enable-order-alerts" type="button">{copy.alertButton}</button>
        <span class="alert-status" id="order-alert-status">{copy.alertOff}</span>
      </div>
    </div>

    {!hasPersistentStore ? (
      <div class="storage-warning card">
        {copy.storageWarning}
      </div>
    ) : null}

    <section class="orders-section">
      <div class="orders-head">
        <div>
          <p class="eyebrow orders-eyebrow">{copy.liveQueue}</p>
          <h2>{copy.processing}</h2>
        </div>
        <p class="orders-meta">{processingOrders.length} {copy.orders}</p>
      </div>

      {processingOrders.length ? (
        <div class="order-list">
          {processingOrders.map((order) => (
            <article
              class:list={["card order-card", orderTone(order)]}
              data-order-id={order.id}
              data-order-no={order.orderNo}
            >
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || copy.guest}</h3>
                  <p class="order-subcopy">
                    {itemCountLabel(order.items.length)}
                    {" · "}
                    {fulfillmentLabel(order.fulfillment)}
                    {" · "}
                    {formatDate(order.createdAt)}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-preview">
                {order.items.slice(0, 3).map((item) => (
                  <div class="preview-item">
                    <img src={item.imageUrl} alt={item.productName} />
                    <div class="preview-copy">
                      <strong>{item.productName}</strong>
                      <span>{formatPreviewQuantity(item.quantity, item.subtotal)}</span>
                    </div>
                  </div>
                ))}
                {order.items.length > 3 ? <p class="preview-more">+{order.items.length - 3} {copy.moreItems}</p> : null}
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
              <div class="order-actions">
                <a class="detail-link" href={`/admin/orders/${order.orderNo}${uiLang === "zh" ? "?ui=zh" : ""}`}>{copy.viewDetails}</a>
                {queueActions(order).map((action) => (
                  <button
                    class:list={["queue-action", action.tone === "danger" ? "danger" : "primary"]}
                    type="button"
                    data-inline-action="true"
                    data-order-no={order.orderNo}
                    data-endpoint={action.endpoint}
                    data-method={action.method}
                    data-payload={action.payload ? JSON.stringify(action.payload) : ""}
                  >
                    {action.label}
                  </button>
                ))}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="card table-empty">{copy.noProcessing}</div>
      )}
    </section>

    <section class="orders-section secondary-section">
      <div class="orders-head">
        <div>
          <p class="eyebrow orders-eyebrow">{copy.history}</p>
          <h2>{copy.completed}</h2>
        </div>
        <p class="orders-meta">{completedOrders.length} {copy.orders}</p>
      </div>

      {completedOrders.length ? (
        <div class="order-list">
          {completedOrders.map((order) => (
            <a class:list={["card order-card", orderTone(order)]} href={`/admin/orders/${order.orderNo}${uiLang === "zh" ? "?ui=zh" : ""}`} data-order-id={order.id}>
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || copy.guest}</h3>
                  <p class="order-subcopy">
                    {itemCountLabel(order.items.length)}
                    {" · "}
                    {formatDate(order.createdAt)}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="card table-empty">{copy.noCompleted}</div>
      )}
    </section>

    {closedOrders.length ? (
      <section class="orders-section secondary-section">
        <div class="orders-head">
          <div>
            <p class="eyebrow orders-eyebrow">{copy.closed}</p>
            <h2>{copy.cancelledRefunded}</h2>
          </div>
          <p class="orders-meta">{closedOrders.length} {copy.orders}</p>
        </div>
        <div class="order-list">
          {closedOrders.map((order) => (
            <a class:list={["card order-card", orderTone(order)]} href={`/admin/orders/${order.orderNo}${uiLang === "zh" ? "?ui=zh" : ""}`} data-order-id={order.id}>
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || copy.guest}</h3>
                  <p class="order-subcopy">
                    {itemCountLabel(order.items.length)}
                    {" · "}
                    {formatDate(order.createdAt)}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </section>
</BaseLayout>

<script
  is:inline
  type="application/json"
  id="admin-orders-copy"
  set:html={JSON.stringify({
    alertOn: copy.alertOn,
    alertFailed: copy.alertFailed,
    alertNew: copy.alertNew,
    updateError: copy.updateError,
    updating: copy.updating,
    notifyTitle: copy.notifyTitle,
  })}
/>

<script is:inline>
  const alertButton = document.getElementById("enable-order-alerts");
  const alertStatus = document.getElementById("order-alert-status");
  const copyNode = document.getElementById("admin-orders-copy");
  const rowNodes = document.querySelectorAll("[data-order-id]");
  const storageKey = "sumi-ramen-order-alerts-enabled";
  const seenOrdersKey = "sumi-ramen-seen-orders";
  const initialOrderIds = Array.from(rowNodes).map((node) => node.getAttribute("data-order-id")).filter(Boolean);
  const seenOrders = new Set(initialOrderIds);
  let audioContext;
  let alertsEnabled = false;

  try {
    const storedSeenOrders = JSON.parse(window.localStorage.getItem(seenOrdersKey) || "[]");
    if (Array.isArray(storedSeenOrders)) {
      storedSeenOrders.forEach((id) => {
        if (typeof id === "string" && id) {
          seenOrders.add(id);
        }
      });
    }
  } catch {
    // Ignore malformed storage data.
  }

  const persistSeenOrders = () => {
    try {
      window.localStorage.setItem(seenOrdersKey, JSON.stringify(Array.from(seenOrders)));
    } catch {
      // Ignore storage failures.
    }
  };

  persistSeenOrders();

  const copy = JSON.parse(copyNode?.textContent || "{}");

  const setStatus = (message) => {
    if (alertStatus) {
      alertStatus.textContent = message;
    }
  };

  const setAlertsEnabled = (enabled) => {
    alertsEnabled = enabled;
    try {
      window.localStorage.setItem(storageKey, enabled ? "true" : "false");
    } catch {
      // Ignore storage failures.
    }
  };

  const playOrderTone = () => {
    if (!audioContext) return;
    const now = audioContext.currentTime;
    const notes = [740, 988, 740];

    notes.forEach((frequency, index) => {
      const oscillator = audioContext.createOscillator();
      const gain = audioContext.createGain();
      oscillator.type = "sine";
      oscillator.frequency.value = frequency;
      gain.gain.setValueAtTime(0.001, now + index * 0.18);
      gain.gain.exponentialRampToValueAtTime(0.08, now + index * 0.18 + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.001, now + index * 0.18 + 0.16);
      oscillator.connect(gain);
      gain.connect(audioContext.destination);
      oscillator.start(now + index * 0.18);
      oscillator.stop(now + index * 0.18 + 0.18);
    });
  };

  const notifyNewOrder = (order) => {
    if ("Notification" in window && Notification.permission === "granted") {
      new Notification(copy.notifyTitle, {
        body: `${order.orderNo} · ${order.orderStatus.replaceAll("_", " ")}`,
      });
    }
    playOrderTone();
  };

  const pollOrders = async () => {
    if (!alertsEnabled) return;

    try {
      const response = await fetch("/api/admin/orders");
      const data = await response.json();
      const orders = Array.isArray(data?.orders) ? data.orders : [];
      const newOrders = orders.filter((order) => order?.id && !seenOrders.has(order.id));

      if (newOrders.length) {
        newOrders.forEach((order) => seenOrders.add(order.id));
        persistSeenOrders();
        notifyNewOrder(newOrders[0]);
        setStatus(`${copy.alertNew}: ${newOrders[0].orderNo}`);
        window.setTimeout(() => window.location.reload(), 1200);
        return;
      }

      setStatus(copy.alertOn);
    } catch {
      setStatus(copy.alertFailed);
    }
  };

  if (alertButton instanceof HTMLButtonElement) {
    alertButton.addEventListener("click", async () => {
      try {
        audioContext = audioContext || new window.AudioContext();
        if (audioContext.state === "suspended") {
          await audioContext.resume();
        }
      } catch {
        // Ignore audio init failures.
      }

      if ("Notification" in window && Notification.permission === "default") {
        await Notification.requestPermission().catch(() => "default");
      }

      setAlertsEnabled(true);
      alertButton.disabled = true;
      setStatus(copy.alertOn);
      window.setInterval(() => {
        void pollOrders();
      }, 12000);
      void pollOrders();
    });
  }

  try {
    if (window.localStorage.getItem(storageKey) === "true" && alertButton instanceof HTMLButtonElement) {
      setAlertsEnabled(true);
      alertButton.disabled = true;
      setStatus(copy.alertOn);
      window.setInterval(() => {
        void pollOrders();
      }, 12000);
      void pollOrders();
    }
  } catch {
    // Ignore storage failures.
  }

  const inlineButtons = document.querySelectorAll("[data-inline-action='true']");
  for (const node of inlineButtons) {
    node.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      if (!(node instanceof HTMLButtonElement)) return;
      const orderNo = node.dataset.orderNo;
      const endpoint = node.dataset.endpoint;
      const method = node.dataset.method || "POST";
      const rawPayload = node.dataset.payload;
      const payload = rawPayload ? JSON.parse(rawPayload) : undefined;

      if (!orderNo || !endpoint) return;

      node.disabled = true;
      const previousLabel = node.textContent;
      node.textContent = copy.updating;

      try {
        const response = await fetch(`/api/admin/orders/${orderNo}/${endpoint}`, {
          method,
          headers: {
            "Content-Type": "application/json",
          },
          body: payload ? JSON.stringify(payload) : undefined,
        });

        if (!response.ok) {
          const data = await response.json().catch(() => ({}));
          window.alert(data?.error || copy.updateError);
          node.disabled = false;
          node.textContent = previousLabel;
          return;
        }

        window.location.reload();
      } catch {
        window.alert(copy.updateError);
        node.disabled = false;
        node.textContent = previousLabel;
      }
    });
  }
</script>

<style>
  :global(body) {
    background:
      linear-gradient(180deg, #eef6ff 0%, #f8fbff 42%, #ffffff 100%);
    color: #12314b;
  }
  :global(.site-header .header-shell) {
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(247,251,255,.94)),
      rgba(255,255,255,.92);
    border-color: rgba(45,108,223,.12);
    box-shadow: 0 16px 40px rgba(16,78,157,.08);
  }
  :global(.site-header .brand-mark) {
    color: #174ea6;
  }
  :global(.site-header .locale-menu) {
    display: none;
  }
  :global(.site-header .locale-popover) {
    background: #ffffff;
    border-color: rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(16,78,157,.08);
  }
  :global(.site-header .locale-trigger),
  :global(.site-header .locale-option),
  :global(.site-header .header-order) {
    color: rgba(18,49,75,.72);
  }
  :global(.site-header .header-order) {
    border-color: rgba(45,108,223,.14);
    background: rgba(45,108,223,.06);
  }
  .admin-shell {
    padding: 140px 0 88px;
    color: #12314b;
  }
  .page-copy {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 18px 26px;
    align-items: end;
    margin-bottom: 28px;
  }
  .page-copy .section-copy {
    max-width: 42rem;
    margin: 0;
    color: rgba(18,49,75,.72);
  }
  .admin-eyebrow,
  .orders-eyebrow {
    color: #2d6cdf;
  }
  .alert-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .admin-lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.14);
    background: #ffffff;
  }
  .lang-button {
    min-height: 38px;
    padding: 0 12px;
    border-radius: 999px;
    color: rgba(18,49,75,.68);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .lang-button.active {
    background: rgba(45,108,223,.08);
    color: #174ea6;
  }
  .alert-toggle {
    min-height: 46px;
    border-color: rgba(45,108,223,.16);
    background: #ffffff;
    color: #174ea6;
  }
  .alert-status,
  .order-no,
  .orders-meta {
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .alert-status,
  .orders-meta {
    color: rgba(18,49,75,.56);
  }
  .storage-warning {
    margin-bottom: 22px;
    padding: 18px 20px;
    color: #12314b;
    line-height: 1.7;
    border-color: rgba(45,108,223,.16);
    background:
      linear-gradient(180deg, rgba(45,108,223,.06), rgba(45,108,223,.03)),
      #f7fbff;
  }
  .orders-section {
    display: grid;
    gap: 16px;
  }
  .secondary-section {
    margin-top: 34px;
  }
  .orders-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
  }
  .orders-head h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.2rem);
  }
  .order-list {
    display: grid;
    gap: 14px;
  }
  .order-card {
    padding: 18px 20px;
    display: grid;
    gap: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.08);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }
  .order-card:hover {
    transform: translateY(-2px);
    border-color: rgba(45,108,223,.26);
  }
  .order-preview {
    display: grid;
    gap: 10px;
  }
  .preview-item {
    display: grid;

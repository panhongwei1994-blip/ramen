---
import AdminHeader from "@/components/admin/AdminHeader.astro";
import AdminLayout from "@/components/layout/AdminLayout.astro";
import { formatPrice } from "@/data/site";
import { ACTIVE_ORDER_STATUSES, getRuntimeEnv, hasPersistentOrderStore, listOrders, type OrderRecord } from "@/lib/orders";
import { buildAdminHref, buildOrderDetailHref, getAdminLangFromUrl, getAdminModeFromUrl } from "@/lib/admin-links";

export const prerender = false;

const uiLang = getAdminLangFromUrl(Astro.url);
const isZh = uiLang === "zh";
const adminMode = getAdminModeFromUrl(Astro.url);
const isKitchenMode = adminMode === "kitchen";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const orders = await listOrders(runtimeEnv, { statuses: ACTIVE_ORDER_STATUSES });

const hasPersistentStore = hasPersistentOrderStore(runtimeEnv);
const format = (value: number) => formatPrice(value, "en");
const historyHref = buildAdminHref("/admin/orders/history", Astro.url.searchParams, { lang: uiLang, mode: adminMode, viewAll: false });
const orderDetailHref = (orderNo: string) => buildOrderDetailHref(orderNo, { lang: uiLang, mode: adminMode });
const copy = isZh
  ? {
      pageEyebrow: "后台订单",
      pageTitle: isKitchenMode ? "后厨出餐队列" : "订单",
      pageCopy: isKitchenMode ? "给后厨看的精简出餐视图，只保留当前要处理的队列和关键操作。" : "给前台员工使用的订单队列：查找订单、筛选状态，并快速推进出餐。",
      langEn: "EN",
      langZh: "中文",
      modeFront: "前台模式",
      modeKitchen: "后厨模式",
      alertButton: "开启通知",
      alertOff: "通知关闭",
      alertOn: "通知已开启",
      alertFailed: "通知轮询失败",
      alertNew: "新订单",
      storageWarning: "当前部署没有持久化订单存储。请绑定 D1 的 DB，或保留旧的 ORDERS KV，否则结账后后台队列可能为空。",
      liveQueue: "实时队列",
      processing: "订单队列",
      orders: "单",
      noProcessing: "当前没有处理中订单。",
      guest: "游客结账",
      delivery: "外送",
      pickup: "自取",
      moreItems: "更多菜品",
      viewDetails: "查看详情",
      updateError: "更新订单失败。",
      updating: "更新中...",
      notifyTitle: "新订单来了",
      actionAccept: "接单",
      actionCancel: "取消",
      actionCooking: "开始制作",
      actionDelivery: "标记备好",
      actionComplete: "完成",
      historyButton: "历史订单",
      cash: "现金",
      card: "卡支付",
      navOrders: "订单队列",
      navProducts: "菜品管理",
      navSettings: "店铺设置",
      filterAll: "全部",
      filterNew: "新订单",
      filterPreparing: "制作中",
      filterReady: "已备好",
      filterCompleted: "已完成",
      filterCancelled: "已取消",
      searchPlaceholder: isKitchenMode ? "搜索订单号或姓名" : "搜索订单号、姓名或电话",
      noMatches: "没有匹配的订单。",
      confirmCancel: "确认取消这笔订单？",
      kitchenQueue: "出餐队列",
      kitchenEmpty: "当前没有待处理订单。",
      kitchenQueuedAt: "下单时间",
    }
  : {
      pageEyebrow: "Merchant Orders",
      pageTitle: isKitchenMode ? "Kitchen Queue" : "Orders",
      pageCopy: isKitchenMode ? "A compact kitchen-first queue that keeps only the active tickets and the next action visible." : "A front-of-house queue for finding orders, scanning status, and moving service forward quickly.",
      langEn: "EN",
      langZh: "中文",
      modeFront: "Front mode",
      modeKitchen: "Kitchen mode",
      alertButton: "Enable order alerts",
      alertOff: "Alerts off",
      alertOn: "Alerts on",
      alertFailed: "Alert polling failed",
      alertNew: "New order",
      storageWarning: "This deployment is running without persistent order storage. Bind a D1 database as DB or keep the legacy ORDERS KV binding enabled, otherwise the admin queue can look empty after checkout.",
      liveQueue: "Live queue",
      processing: "Order queue",
      orders: "orders",
      noProcessing: "No processing orders.",
      guest: "Guest checkout",
      delivery: "delivery",
      pickup: "pickup",
      moreItems: "more items",
      viewDetails: "View details",
      updateError: "Unable to update order.",
      updating: "Updating...",
      notifyTitle: "New order received",
      actionAccept: "Accept",
      actionCancel: "Cancel order",
      actionCooking: "Start preparing",
      actionDelivery: "Mark ready",
      actionComplete: "Complete",
      historyButton: "Order history",
      cash: "Cash",
      card: "Card",
      navOrders: "Orders",
      navProducts: "Products",
      navSettings: "Settings",
      filterAll: "All",
      filterNew: "New",
      filterPreparing: "Preparing",
      filterReady: "Ready",
      filterCompleted: "Completed",
      filterCancelled: "Cancelled",
      searchPlaceholder: isKitchenMode ? "Search order or name" : "Search order, name, or phone",
      noMatches: "No matching orders.",
      confirmCancel: "Cancel this order?",
      kitchenQueue: "Kitchen queue",
      kitchenEmpty: "No active kitchen tickets.",
      kitchenQueuedAt: "Queued",
    };

const processingStatuses = new Set(["paid_waiting_accept", "accepted", "cooking", "delivering"]);
const sortOrdersByCreatedAtAsc = (left: OrderRecord, right: OrderRecord) =>
  new Date(left.createdAt).getTime() - new Date(right.createdAt).getTime();

const processingOrders = orders.filter((order) => processingStatuses.has(order.orderStatus)).sort(sortOrdersByCreatedAtAsc);
const visibleFilterGroups = ["all", "new", "preparing", "ready"];
const addressPreview = (order: OrderRecord) => {
  if (order.fulfillment === "pickup") return isZh ? "自取" : "Pickup";
  return order.address || (isZh ? "未填写地址" : "No address");
};
const kitchenSearchPreview = (order: OrderRecord) => `${order.orderNo} ${order.customerName}`.trim();

type QueueAction = {
  label: string;
  endpoint: string;
  method: "POST";
  payload?: {
    status: string;
    message: string;
  };
  tone?: "danger";
};

function statusLabel(value: string) {
  if (!isZh) {
    return ({
      paid_waiting_accept: "New",
      accepted: "New",
      cooking: "Preparing",
      delivering: "Ready",
      completed: "Completed",
      cancelled: "Cancelled",
      refunded: "Refunded",
      paid: "Paid",
      unpaid: "Unpaid",
      failed: "Failed",
    } as Record<string, string>)[value] ?? value.replaceAll("_", " ");
  }
  return ({
    pending_payment: "待支付",
    paid_waiting_accept: "新订单",
    accepted: "新订单",
    cooking: "制作中",
    delivering: "已备好",
    completed: "已完成",
    cancelled: "已取消",
    refunded: "已退款",
    paid: "已支付",
    unpaid: "未支付",
    failed: "失败",
    refunded_payment: "已退款",
  } as Record<string, string>)[value] ?? value.replaceAll("_", " ");
}

function statusGroup(order: OrderRecord) {
  if (order.orderStatus === "paid_waiting_accept" || order.orderStatus === "accepted") return "new";
  if (order.orderStatus === "cooking") return "preparing";
  if (order.orderStatus === "delivering") return "ready";
  if (order.orderStatus === "completed") return "completed";
  if (order.orderStatus === "cancelled" || order.orderStatus === "refunded") return "cancelled";
  return "new";
}

function itemCountLabel(count: number) {
  return isZh ? `${count} 件菜品` : `${count} items`;
}

function fulfillmentLabel(value: OrderRecord["fulfillment"]) {
  if (value === "delivery") return copy.delivery;
  return copy.pickup;
}

function formatDate(value: string) {
  return new Date(value).toLocaleString(isZh ? "zh-CN" : "en-US", { dateStyle: "medium", timeStyle: "short" });
}

function formatPreviewQuantity(quantity: number, subtotal: number) {
  return isZh ? `${quantity} 份 · ${format(subtotal)}` : `${quantity} × ${format(subtotal)}`;
}

function orderTone(order: OrderRecord) {
  if (order.orderStatus === "pending_payment" || order.orderStatus === "paid_waiting_accept") return "urgent";
  if (order.orderStatus === "accepted" || order.orderStatus === "cooking" || order.orderStatus === "delivering") return "active";
  if (order.orderStatus === "completed") return "done";
  if (order.orderStatus === "cancelled" || order.orderStatus === "refunded") return "muted";
  return "neutral";
}

function queueActions(order: OrderRecord): QueueAction[] {
  switch (order.orderStatus) {
    case "paid_waiting_accept":
      return [
        { label: copy.actionAccept, endpoint: "accept", method: "POST" },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST", tone: "danger" },
      ];
    case "accepted":
      return [
        { label: copy.actionCooking, endpoint: "status", method: "POST", payload: { status: "cooking", message: "Kitchen started preparing the order." } },
        { label: copy.actionCancel, endpoint: "cancel", method: "POST", tone: "danger" },
      ];
    case "cooking":
      return [
        { label: copy.actionDelivery, endpoint: "status", method: "POST", payload: { status: "delivering", message: "Order marked ready." } },
      ];
    case "delivering":
      return [
        { label: copy.actionComplete, endpoint: "status", method: "POST", payload: { status: "completed", message: "Order marked as completed." } },
      ];
    default:
      return [];
  }
}

function kitchenCancelAction(order: OrderRecord) {
  return queueActions(order).find((action) => action.endpoint === "cancel");
}

function kitchenPrimaryActions(order: OrderRecord) {
  return queueActions(order).filter((action) => action.endpoint !== "cancel");
}
---

<AdminLayout lang={uiLang} title={isZh ? "订单后台 | Sumi Ramen" : "Orders | Sumi Ramen Admin"}>
  <section class="container admin-shell" data-ui-lang={uiLang} data-admin-mode={adminMode}>
    <AdminHeader
      lang={uiLang}
      mode={adminMode}
      pathname={Astro.url.pathname}
      searchParams={Astro.url.searchParams}
      activeNav="orders"
      eyebrow={copy.pageEyebrow}
      title={copy.pageTitle}
      copy={copy.pageCopy}
      navLabels={{
        orders: copy.navOrders,
        products: copy.navProducts,
        settings: copy.navSettings,
      }}
      langLabels={{ en: copy.langEn, zh: copy.langZh }}
      modeLabels={{ front: copy.modeFront, kitchen: copy.modeKitchen }}
    >
      {!isKitchenMode ? <a slot="actions" class="ghost-button alert-toggle" href={historyHref}>{copy.historyButton}</a> : null}
      <button slot="actions" class="ghost-button alert-toggle" id="enable-order-alerts" type="button">{copy.alertButton}</button>
      <span slot="actions" class="alert-status" id="order-alert-status">{copy.alertOff}</span>
    </AdminHeader>

    <div class="order-toolbar card" role="search">
      <div class="filter-tabs" aria-label="Order status filters">
        {visibleFilterGroups.includes("all") ? <button class="filter-tab active" type="button" data-filter="all">{copy.filterAll}</button> : null}
        {visibleFilterGroups.includes("new") ? <button class="filter-tab" type="button" data-filter="new">{copy.filterNew}</button> : null}
        {visibleFilterGroups.includes("preparing") ? <button class="filter-tab" type="button" data-filter="preparing">{copy.filterPreparing}</button> : null}
        {visibleFilterGroups.includes("ready") ? <button class="filter-tab" type="button" data-filter="ready">{copy.filterReady}</button> : null}
        {visibleFilterGroups.includes("completed") ? <button class="filter-tab" type="button" data-filter="completed">{copy.filterCompleted}</button> : null}
        {visibleFilterGroups.includes("cancelled") ? <button class="filter-tab" type="button" data-filter="cancelled">{copy.filterCancelled}</button> : null}
      </div>
      <label class="order-search">
        <span class="sr-only">{copy.searchPlaceholder}</span>
        <input id="order-search-input" type="search" placeholder={copy.searchPlaceholder} autocomplete="off" />
      </label>
    </div>
    <div class="card table-empty no-match-panel" id="no-matching-orders" hidden>{copy.noMatches}</div>

    {!hasPersistentStore ? (
      <div class="storage-warning card">
        {copy.storageWarning}
      </div>
    ) : null}

    <section class="orders-section">
      <div class="orders-head">
        <div>
          <p class="eyebrow orders-eyebrow">{isKitchenMode ? copy.kitchenQueue : copy.liveQueue}</p>
          <h2>{isKitchenMode ? copy.kitchenQueue : copy.processing}</h2>
        </div>
        <p class="orders-meta">{processingOrders.length} {copy.orders}</p>
      </div>

      {processingOrders.length ? (
        <div class:list={["order-list", { "kitchen-grid": isKitchenMode }]}>
          {processingOrders.map((order) => {
            const cancelAction = kitchenCancelAction(order);
            const primaryActions = kitchenPrimaryActions(order);

            return (
              <article
                class:list={["card order-card", orderTone(order), { "kitchen-card": isKitchenMode }]}
                data-order-id={order.id}
                data-order-no={order.orderNo}
                data-status-group={statusGroup(order)}
                data-search={isKitchenMode ? kitchenSearchPreview(order) : `${order.orderNo} ${order.customerName} ${order.phone} ${order.address}`}
              >
                {isKitchenMode ? (
                  <>
                    <div class="kitchen-card-top">
                      <div>
                        <p class="order-no">{order.orderNo}</p>
                        <h3>{order.customerName || copy.guest}</h3>
                      </div>
                      <div class="kitchen-status-row">
                        <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                        {cancelAction ? (
                          <button
                            class="queue-action danger kitchen-cancel-button"
                            type="button"
                            data-inline-action="true"
                            data-order-no={order.orderNo}
                            data-endpoint={cancelAction.endpoint}
                            data-method={cancelAction.method}
                            data-payload={cancelAction.payload ? JSON.stringify(cancelAction.payload) : ""}
                          >
                            {cancelAction.label}
                          </button>
                        ) : null}
                      </div>
                    </div>
                    <p class="order-subcopy kitchen-subcopy">
                      {copy.kitchenQueuedAt} · {formatDate(order.createdAt)}
                    </p>
                    <div class="order-rail kitchen-rail">
                      <span class:list={["fulfillment-highlight", order.fulfillment]}>{fulfillmentLabel(order.fulfillment)}</span>
                      <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                        {statusLabel(order.paymentStatus)}
                      </span>
                    </div>
                    {order.remark ? <p class="order-note">{order.remark}</p> : null}
                    <div class="order-preview kitchen-preview">
                      {order.items.map((item) => (
                        <div class="preview-item kitchen-preview-item">
                          <img src={item.imageUrl} alt={`${item.productName} preview`} loading="lazy" width="56" height="56" />
                          <div class="preview-copy">
                            <strong>{item.quantity}× {item.productName}</strong>
                            <span>{formatPreviewQuantity(item.quantity, item.subtotal)}</span>
                            {item.addOns.length ? (
                              <p class="preview-addon kitchen-addon">{item.addOns.map((addOn) => addOn.label).join(" · ")}</p>
                            ) : null}
                            {item.note ? <p class="preview-note">{item.note}</p> : null}
                          </div>
                        </div>
                      ))}
                    </div>
                    <div class="order-actions kitchen-actions">
                      {primaryActions.map((action) => (
                        <button
                          class:list={["queue-action", action.tone === "danger" ? "danger" : "primary"]}
                          type="button"
                          data-inline-action="true"
                          data-order-no={order.orderNo}
                          data-endpoint={action.endpoint}
                          data-method={action.method}
                          data-payload={action.payload ? JSON.stringify(action.payload) : ""}
                        >
                          {action.label}
                        </button>
                      ))}
                    </div>
                  </>
                ) : (
                  <>
                    <div class="order-main">
                      <div>
                        <p class="order-no">{order.orderNo}</p>
                        <h3>
                          <span>{order.customerName || copy.guest}</span>
                          <small>{addressPreview(order)}</small>
                        </h3>
                        <p class="order-subcopy">
                          {itemCountLabel(order.items.length)}
                          {" · "}
                          <span class:list={["fulfillment-highlight", order.fulfillment]}>{fulfillmentLabel(order.fulfillment)}</span>
                          {" · "}
                          {order.phone || "No phone"}
                          {" · "}
                          {formatDate(order.createdAt)}
                        </p>
                        {order.remark ? <p class="order-note">{order.remark}</p> : null}
                      </div>
                      <div class="order-total">{format(order.totalAmount)}</div>
                    </div>
                    <div class="order-preview">
                      {order.items.slice(0, 3).map((item) => (
                        <div class="preview-item">
                          <img src={item.imageUrl} alt={`${item.productName} preview`} loading="lazy" width="56" height="56" />
                          <div class="preview-copy">
                            <strong>{item.productName}</strong>
                            <span>{formatPreviewQuantity(item.quantity, item.subtotal)}</span>
                            {item.addOns.length ? (
                              <p class="preview-addon">{item.addOns.map((addOn) => addOn.label).join(" · ")}</p>
                            ) : null}
                            {item.note ? <p class="preview-note">{item.note}</p> : null}
                          </div>
                        </div>
                      ))}
                      {order.items.length > 3 ? <p class="preview-more">+{order.items.length - 3} {copy.moreItems}</p> : null}
                    </div>
                    <div class="order-rail">
                      <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                      <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                        {statusLabel(order.paymentStatus)}
                      </span>
                      <span class:list={["method-pill", order.paymentMethod]}>
                        {order.paymentMethod === "cash" ? copy.cash : copy.card}
                      </span>
                    </div>
                    <div class="order-actions">
                      <a class="detail-link" href={orderDetailHref(order.orderNo)}>{copy.viewDetails}</a>
                      {queueActions(order).map((action) => (
                        <button
                          class:list={["queue-action", action.tone === "danger" ? "danger" : "primary"]}
                          type="button"
                          data-inline-action="true"
                          data-order-no={order.orderNo}
                          data-endpoint={action.endpoint}
                          data-method={action.method}
                          data-payload={action.payload ? JSON.stringify(action.payload) : ""}
                        >
                          {action.label}
                        </button>
                      ))}
                    </div>
                  </>
                )}
              </article>
            );
          })}
        </div>
      ) : (
        <div class="card table-empty">{isKitchenMode ? copy.kitchenEmpty : copy.noProcessing}</div>
      )}
    </section>

    <script
      is:inline
      type="application/json"
      id="admin-orders-copy"
      set:html={JSON.stringify({
        alertOn: copy.alertOn,
        alertFailed: copy.alertFailed,
        alertNew: copy.alertNew,
        updateError: copy.updateError,
        updating: copy.updating,
        notifyTitle: copy.notifyTitle,
        confirmCancel: copy.confirmCancel,
        allOrderIds: processingOrders.map((order) => order.id),
      })}
    />

    <script is:inline>
      const alertButton = document.getElementById("enable-order-alerts");
      const alertStatus = document.getElementById("order-alert-status");
      const copyNode = document.getElementById("admin-orders-copy");
      const storageKey = "sumi-ramen-order-alerts-enabled";
      const seenOrdersKey = "sumi-ramen-seen-orders";
      const alertRefreshDelayMs = 5000;

      const copy = JSON.parse(copyNode?.textContent || "{}");
      const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
      const searchInput = document.getElementById("order-search-input");
      const noMatches = document.getElementById("no-matching-orders");
      const initialOrderIds = copy.allOrderIds || [];
      const seenOrders = new Set(initialOrderIds);
      let audioContext;
      let alertsEnabled = false;
      let pollTimer = null;

      try {
        const storedSeenOrders = JSON.parse(window.localStorage.getItem(seenOrdersKey) || "[]");
        if (Array.isArray(storedSeenOrders)) {
          storedSeenOrders.forEach((id) => {
            if (typeof id === "string" && id) {
              seenOrders.add(id);
            }
          });
        }
      } catch {
        // Ignore malformed storage data.
      }

      const persistSeenOrders = () => {
        try {
          window.localStorage.setItem(seenOrdersKey, JSON.stringify(Array.from(seenOrders)));
        } catch {
          // Ignore storage failures.
        }
      };

      persistSeenOrders();

      const getCardMeta = (card) => {
        const marker = card.querySelector("[data-status-group]");
        return {
          status: card.dataset.statusGroup || marker?.getAttribute("data-status-group") || "",
          search: (card.dataset.search || marker?.getAttribute("data-search") || "").toLowerCase(),
        };
      };

      const applyOrderFilters = () => {
        const activeFilter = document.querySelector("[data-filter].active")?.getAttribute("data-filter") || "all";
        const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
        let visibleCount = 0;

        document.querySelectorAll(".order-card").forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const meta = getCardMeta(card);
          const statusMatch = activeFilter === "all" || meta.status === activeFilter;
          const queryMatch = !query || meta.search.includes(query);
          const visible = statusMatch && queryMatch;
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        if (noMatches instanceof HTMLElement) {
          noMatches.hidden = visibleCount > 0;
        }
      };

      filterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          filterButtons.forEach((item) => item.classList.remove("active"));
          button.classList.add("active");
          applyOrderFilters();
        });
      });

      if (searchInput instanceof HTMLInputElement) {
        searchInput.addEventListener("input", applyOrderFilters);
      }

      const setStatus = (message) => {
        if (alertStatus) {
          alertStatus.textContent = message;
        }
      };

      const setAlertsEnabled = (enabled) => {
        alertsEnabled = enabled;
        if (alertButton instanceof HTMLButtonElement) {
          alertButton.dataset.enabled = enabled ? "true" : "false";
          alertButton.setAttribute("aria-pressed", enabled ? "true" : "false");
        }
        try {
          window.localStorage.setItem(storageKey, enabled ? "true" : "false");
        } catch {
          // Ignore storage failures.
        }
      };

      const startAlertPolling = () => {
        setAlertsEnabled(true);
        setStatus(copy.alertOn);
        if (pollTimer) return;
        pollTimer = window.setInterval(() => {
          void pollOrders();
        }, 5000);
        void pollOrders();
      };

      const playOrderTone = () => {
        try {
          const AudioContextCtor = window.AudioContext || window["webkitAudioContext"];
          audioContext = audioContext || new AudioContextCtor();
          if (audioContext.state === "suspended") {
            void audioContext.resume();
          }
        } catch {
          return;
        }
        if (!audioContext) return;
        const now = audioContext.currentTime;
        const notes = [784, 988, 1175, 988, 784];
        const loopCount = 9;
        const loopDuration = 1.08;

        for (let loopIndex = 0; loopIndex < loopCount; loopIndex += 1) {
          notes.forEach((frequency, noteIndex) => {
            const startTime = now + loopIndex * loopDuration + noteIndex * 0.18;
            const stopTime = startTime + 0.16;
            const oscillator = audioContext.createOscillator();
            const gain = audioContext.createGain();
            oscillator.type = "triangle";
            oscillator.frequency.value = frequency;
            gain.gain.setValueAtTime(0.001, startTime);
            gain.gain.exponentialRampToValueAtTime(0.28, startTime + 0.02);
            gain.gain.exponentialRampToValueAtTime(0.001, stopTime);
            oscillator.connect(gain);
            gain.connect(audioContext.destination);
            oscillator.start(startTime);
            oscillator.stop(stopTime);
          });
        }
      };

      const notifyNewOrder = (order) => {
        if ("Notification" in window && Notification.permission === "granted") {
          new Notification(copy.notifyTitle, {
            body: `${order.orderNo} · ${order.orderStatus.replaceAll("_", " ")}`,
          });
        }
        playOrderTone();
      };

      const pollOrders = async () => {
        if (!alertsEnabled) return;

        try {
          const response = await fetch("/api/admin/orders?summary=alerts");
          const data = await response.json();
          const orders = Array.isArray(data?.orders) ? data.orders : [];
          const alertableOrders = orders.filter(
            (order) =>
              order?.id &&
              (order.paymentStatus === "paid" || order.paymentMethod === "cash") &&
              ["paid_waiting_accept", "accepted", "cooking", "delivering"].includes(order.orderStatus),
          );
          const newOrders = alertableOrders.filter((order) => !seenOrders.has(order.id));

          if (newOrders.length) {
            newOrders.forEach((order) => seenOrders.add(order.id));
            persistSeenOrders();
            notifyNewOrder(newOrders[0]);
            setStatus(`${copy.alertNew}: ${newOrders[0].orderNo}`);
            window.setTimeout(() => window.location.reload(), alertRefreshDelayMs);
            return;
          }

          setStatus(copy.alertOn);
        } catch {
          setStatus(copy.alertFailed);
        }
      };

      try {
        if (window.localStorage.getItem(storageKey) === "true" && alertButton instanceof HTMLButtonElement) {
          startAlertPolling();
        }
      } catch {
        // Ignore storage failures.
      }

      document.addEventListener("click", async (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;

        const alertTrigger = target.closest("#enable-order-alerts");
        if (alertTrigger instanceof HTMLButtonElement) {
          event.preventDefault();
          try {
            audioContext = audioContext || new window.AudioContext();
            if (audioContext.state === "suspended") {
              await audioContext.resume();
            }
          } catch {
            // Ignore audio init failures.
          }

          if ("Notification" in window && Notification.permission === "default") {
            await Notification.requestPermission().catch(() => "default");
          }

          startAlertPolling();
          return;
        }

        const inlineButton = target.closest("[data-inline-action='true']");
        if (!(inlineButton instanceof HTMLButtonElement)) return;

        event.preventDefault();
        event.stopPropagation();

        const orderNo = inlineButton.dataset.orderNo;
        const endpoint = inlineButton.dataset.endpoint;
        const method = inlineButton.dataset.method || "POST";
        const rawPayload = inlineButton.dataset.payload;
        const payload = rawPayload ? JSON.parse(rawPayload) : undefined;

        if (!orderNo || !endpoint) return;

        if (endpoint === "cancel" && !window.confirm(copy.confirmCancel || "Cancel this order?")) {
          return;
        }

        inlineButton.disabled = true;
        const previousLabel = inlineButton.textContent;
        inlineButton.textContent = copy.updating;

        try {
          const response = await fetch(`/api/admin/orders/${orderNo}/${endpoint}`, {
            method,
            headers: {
              "Content-Type": "application/json",
            },
            body: payload ? JSON.stringify(payload) : undefined,
          });

          if (!response.ok) {
            const data = await response.json().catch(() => ({}));
            window.alert(data?.error || copy.updateError);
            inlineButton.disabled = false;
            inlineButton.textContent = previousLabel;
            return;
          }

          window.location.reload();
        } catch {
          window.alert(copy.updateError);
          inlineButton.disabled = false;
          inlineButton.textContent = previousLabel;
        }
      });
    </script>
  </section>
</AdminLayout>


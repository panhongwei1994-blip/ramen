---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getRuntimeEnv, hasPersistentOrderStore, listOrders, type OrderRecord } from "@/lib/orders";

export const prerender = false;

const runtimeEnv = getRuntimeEnv(Astro.locals);
const orders = await listOrders(runtimeEnv);
const hasPersistentStore = hasPersistentOrderStore(runtimeEnv);
const format = (value: number) => formatPrice(value, "en");

const processingStatuses = new Set(["pending_payment", "paid_waiting_accept", "accepted", "cooking", "delivering"]);
const completedStatuses = new Set(["completed"]);
const closedStatuses = new Set(["cancelled", "refunded"]);

const processingOrders = orders.filter((order) => processingStatuses.has(order.orderStatus));
const completedOrders = orders.filter((order) => completedStatuses.has(order.orderStatus));
const closedOrders = orders.filter((order) => closedStatuses.has(order.orderStatus));

function statusLabel(value: string) {
  return value.replaceAll("_", " ");
}

function orderTone(order: OrderRecord) {
  if (order.orderStatus === "pending_payment" || order.orderStatus === "paid_waiting_accept") return "urgent";
  if (order.orderStatus === "accepted" || order.orderStatus === "cooking" || order.orderStatus === "delivering") return "active";
  if (order.orderStatus === "completed") return "done";
  if (order.orderStatus === "cancelled" || order.orderStatus === "refunded") return "muted";
  return "neutral";
}
---

<BaseLayout lang="en">
  <section class="container admin-shell">
    <div class="page-copy">
      <div>
        <p class="eyebrow admin-eyebrow">Merchant Orders</p>
        <h1 class="section-title">Orders</h1>
        <p class="section-copy">Bright, simple queue view for staff. Processing orders are separated from completed history.</p>
      </div>
      <div class="alert-actions">
        <span class="alert-status live" id="order-alert-status">Alerts on</span>
      </div>
    </div>

    {!hasPersistentStore ? (
      <div class="storage-warning card">
        This deployment is running without persistent order storage. Bind a D1 database as <strong>DB</strong> or keep the legacy <strong>ORDERS</strong> KV binding enabled, otherwise the admin queue can look empty after checkout.
      </div>
    ) : null}

    <section class="orders-section">
      <div class="orders-head">
        <div>
          <p class="eyebrow orders-eyebrow">Live queue</p>
          <h2>Processing</h2>
        </div>
        <p class="orders-meta">{processingOrders.length} orders</p>
      </div>

      {processingOrders.length ? (
        <div class="order-list">
          {processingOrders.map((order) => (
            <a
              class:list={["card order-card", orderTone(order)]}
              href={`/admin/orders/${order.orderNo}`}
              data-order-id={order.id}
            >
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || "Guest checkout"}</h3>
                  <p class="order-subcopy">
                    {order.items.length} items
                    {order.fulfillment === "delivery" ? " · delivery" : " · pickup"}
                    {" · "}
                    {new Date(order.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="card table-empty">No processing orders.</div>
      )}
    </section>

    <section class="orders-section secondary-section">
      <div class="orders-head">
        <div>
          <p class="eyebrow orders-eyebrow">History</p>
          <h2>Completed</h2>
        </div>
        <p class="orders-meta">{completedOrders.length} orders</p>
      </div>

      {completedOrders.length ? (
        <div class="order-list">
          {completedOrders.map((order) => (
            <a class:list={["card order-card", orderTone(order)]} href={`/admin/orders/${order.orderNo}`}>
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || "Guest checkout"}</h3>
                  <p class="order-subcopy">
                    {order.items.length} items
                    {" · "}
                    {new Date(order.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="card table-empty">No completed orders yet.</div>
      )}
    </section>

    {closedOrders.length ? (
      <section class="orders-section secondary-section">
        <div class="orders-head">
          <div>
            <p class="eyebrow orders-eyebrow">Closed</p>
            <h2>Cancelled / Refunded</h2>
          </div>
          <p class="orders-meta">{closedOrders.length} orders</p>
        </div>
        <div class="order-list">
          {closedOrders.map((order) => (
            <a class:list={["card order-card", orderTone(order)]} href={`/admin/orders/${order.orderNo}`}>
              <div class="order-main">
                <div>
                  <p class="order-no">{order.orderNo}</p>
                  <h3>{order.customerName || "Guest checkout"}</h3>
                  <p class="order-subcopy">
                    {order.items.length} items
                    {" · "}
                    {new Date(order.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}
                  </p>
                </div>
                <div class="order-total">{format(order.totalAmount)}</div>
              </div>
              <div class="order-rail">
                <span class:list={["status-pill", orderTone(order)]}>{statusLabel(order.orderStatus)}</span>
                <span class:list={["payment-pill", { paid: order.paymentStatus === "paid", unpaid: order.paymentStatus !== "paid" }]}>
                  {statusLabel(order.paymentStatus)}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </section>
</BaseLayout>

<script is:inline>
  const alertStatus = document.getElementById("order-alert-status");
  const rowNodes = document.querySelectorAll("[data-order-id]");
  const seenOrders = new Set(Array.from(rowNodes).map((node) => node.getAttribute("data-order-id")).filter(Boolean));
  let audioContext;
  let alertsEnabled = true;

  const setStatus = (message) => {
    if (alertStatus) {
      alertStatus.textContent = message;
    }
  };

  const playOrderTone = () => {
    if (!audioContext) return;
    const now = audioContext.currentTime;
    const notes = [740, 988, 740];

    notes.forEach((frequency, index) => {
      const oscillator = audioContext.createOscillator();
      const gain = audioContext.createGain();
      oscillator.type = "sine";
      oscillator.frequency.value = frequency;
      gain.gain.setValueAtTime(0.001, now + index * 0.18);
      gain.gain.exponentialRampToValueAtTime(0.08, now + index * 0.18 + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.001, now + index * 0.18 + 0.16);
      oscillator.connect(gain);
      gain.connect(audioContext.destination);
      oscillator.start(now + index * 0.18);
      oscillator.stop(now + index * 0.18 + 0.18);
    });
  };

  const notifyNewOrder = (order) => {
    if ("Notification" in window && Notification.permission === "granted") {
      new Notification("New order received", {
        body: `${order.orderNo} · ${order.orderStatus.replaceAll("_", " ")}`,
      });
    }
    playOrderTone();
  };

  const pollOrders = async () => {
    if (!alertsEnabled) return;

    try {
      const response = await fetch("/api/admin/orders");
      const data = await response.json();
      const orders = Array.isArray(data?.orders) ? data.orders : [];
      const newOrders = orders.filter((order) => order?.id && !seenOrders.has(order.id));

      if (newOrders.length) {
        newOrders.forEach((order) => seenOrders.add(order.id));
        notifyNewOrder(newOrders[0]);
        setStatus(`New order: ${newOrders[0].orderNo}`);
        window.setTimeout(() => window.location.reload(), 1200);
        return;
      }

      setStatus("Alerts on");
    } catch {
      setStatus("Alert polling failed");
    }
  };

  const bootAlerts = async () => {
    try {
      audioContext = audioContext || new window.AudioContext();
    } catch {
      // Ignore audio init failures.
    }

    if ("Notification" in window && Notification.permission === "default") {
      try {
        await Notification.requestPermission();
      } catch {
        // Ignore notification permission failures.
      }
    }

    setStatus("Alerts on");
    window.setInterval(() => {
      void pollOrders();
    }, 12000);
    void pollOrders();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      void bootAlerts();
    }, { once: true });
  } else {
    void bootAlerts();
  }
</script>

<style>
  :global(body) {
    background:
      linear-gradient(180deg, #eef6ff 0%, #f8fbff 42%, #ffffff 100%);
    color: #12314b;
  }
  :global(.site-header .header-shell) {
    background:
      linear-gradient(180deg, rgba(255,255,255,.96), rgba(247,251,255,.94)),
      rgba(255,255,255,.92);
    border-color: rgba(45,108,223,.12);
    box-shadow: 0 16px 40px rgba(16,78,157,.08);
  }
  :global(.site-header .brand-mark) {
    color: #174ea6;
  }
  :global(.site-header .locale-trigger),
  :global(.site-header .locale-option),
  :global(.site-header .header-order) {
    color: rgba(18,49,75,.72);
  }
  :global(.site-header .header-order) {
    border-color: rgba(45,108,223,.14);
    background: rgba(45,108,223,.06);
  }
  .admin-shell {
    padding: 140px 0 88px;
    color: #12314b;
  }
  .page-copy {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 18px 26px;
    align-items: end;
    margin-bottom: 28px;
  }
  .page-copy .section-copy {
    max-width: 42rem;
    margin: 0;
    color: rgba(18,49,75,.72);
  }
  .admin-eyebrow,
  .orders-eyebrow {
    color: #2d6cdf;
  }
  .alert-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .alert-status,
  .order-no,
  .orders-meta {
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .alert-status,
  .orders-meta {
    color: rgba(18,49,75,.56);
  }
  .alert-status.live {
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.14);
    background: rgba(45,108,223,.08);
    color: #174ea6;
  }
  .storage-warning {
    margin-bottom: 22px;
    padding: 18px 20px;
    color: #12314b;
    line-height: 1.7;
    border-color: rgba(45,108,223,.16);
    background:
      linear-gradient(180deg, rgba(45,108,223,.06), rgba(45,108,223,.03)),
      #f7fbff;
  }
  .orders-section {
    display: grid;
    gap: 16px;
  }
  .secondary-section {
    margin-top: 34px;
  }
  .orders-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
  }
  .orders-head h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.2rem);
  }
  .order-list {
    display: grid;
    gap: 14px;
  }
  .order-card {
    padding: 18px 20px;
    display: grid;
    gap: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.98), rgba(247,251,255,.98)),
      #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 18px 48px rgba(15,76,153,.08);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }
  .order-card:hover {
    transform: translateY(-2px);
    border-color: rgba(45,108,223,.26);
  }
  .order-main,
  .order-rail {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
  }
  .order-no {
    margin: 0 0 10px;
    color: #2d6cdf;
  }
  .order-card h3 {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.05;
  }
  .order-subcopy {
    margin: 8px 0 0;
    color: rgba(18,49,75,.64);
  }
  .order-total {
    padding: 12px 16px;
    border-radius: 18px;
    border: 1px solid rgba(45,108,223,.14);
    background: rgba(45,108,223,.08);
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    white-space: nowrap;
    color: #174ea6;
  }
  .status-pill,
  .payment-pill {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    font-family: "Trebuchet MS", "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(45,108,223,.12);
    color: #12314b;
  }
  .status-pill.urgent,
  .order-card.urgent {
    border-color: rgba(207,69,72,.24);
    background:
      linear-gradient(180deg, rgba(255,244,244,.98), rgba(255,250,250,.98)),
      #ffffff;
  }
  .status-pill.active,
  .order-card.active {
    border-color: rgba(45,108,223,.22);
    background:
      linear-gradient(180deg, rgba(248,251,255,.98), rgba(255,255,255,.98)),
      #ffffff;
  }
  .status-pill.done,
  .order-card.done {
    border-color: rgba(77,168,126,.24);
    background:
      linear-gradient(180deg, rgba(246,255,250,.98), rgba(255,255,255,.98)),
      #ffffff;
  }
  .status-pill.muted,
  .order-card.muted {
    opacity: 0.78;
  }
  .payment-pill.paid {
    background: rgba(77,168,126,.12);
    border-color: rgba(77,168,126,.24);
  }
  .payment-pill.unpaid {
    background: rgba(207,69,72,.1);
    border-color: rgba(207,69,72,.2);
  }
  .table-empty {
    padding: 28px 22px;
    color: rgba(18,49,75,.64);
    background: rgba(255,255,255,.96);
  }
  @media (max-width: 760px) {
    .page-copy,
    .orders-head,
    .order-main,
    .order-rail {
      display: grid;
    }
    .order-total {
      width: fit-content;
    }
  }
</style>

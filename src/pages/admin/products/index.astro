---
import AdminHeader from "@/components/admin/AdminHeader.astro";
import AdminLayout from "@/components/layout/AdminLayout.astro";
import { getProductsFromD1, getCategoriesFromD1, getRuntimeEnv } from "@/lib/orders";
import { formatPrice } from "@/data/site";
import { getAdminLangFromUrl, getAdminModeFromUrl } from "@/lib/admin-links";

export const prerender = false;

const uiLang = getAdminLangFromUrl(Astro.url);
const isZh = uiLang === "zh";
const adminMode = getAdminModeFromUrl(Astro.url);
const runtimeEnv = getRuntimeEnv(Astro.locals);

const products = await getProductsFromD1(runtimeEnv);
const categories = await getCategoriesFromD1(runtimeEnv);

const format = (v: number) => formatPrice(v, isZh ? "zh" : "en");

function parseDescription(desc: string) {
  if (!desc) return "";
  try {
    const obj = JSON.parse(desc);
    return obj[isZh ? "zh" : "en"] || obj.en || desc;
  } catch {
    return desc;
  }
}


const copy = isZh
  ? {
      title: "菜品管理",
      subtitle: "管理菜单价格、库存及上架状态。",
      navOrders: "订单队列",
      navProducts: "菜品管理",
      navSettings: "店铺设置",
      langEn: "EN",
      langZh: "中文",
      modeFront: "前台模式",
      modeKitchen: "后厨模式",
      thName: "菜品名称",
      thCategory: "分类",
      thPrice: "价格",
      thInventory: "库存",
      thStatus: "状态",
      thActions: "操作",
      statusAvailable: "上架中",
      statusUnavailable: "已下架",
      edit: "编辑",
      save: "保存",
      cancel: "取消",
      allCats: "所有分类",
      unlimited: "不限",
      updateSuccess: "更新成功",
      updateError: "更新失败",
      statusUpdated: "状态已更新",
      addProduct: "+ 添加菜品",
      addProductTitle: "添加新菜品",
      addProductSuccess: "菜品已添加",
      addProductError: "添加失败",
      imageUrl: "图片链接",
      description: "描述",
      inventoryHint: "库存（不限留空）",
    }
  : {
      title: "Product Management",
      subtitle: "Manage menu prices, inventory, and availability.",
      navOrders: "Orders",
      navProducts: "Products",
      navSettings: "Settings",
      langEn: "EN",
      langZh: "中文",
      modeFront: "Front mode",
      modeKitchen: "Kitchen mode",
      thName: "Name",
      thCategory: "Category",
      thPrice: "Price",
      thInventory: "Inventory",
      thStatus: "Status",
      thActions: "Actions",
      statusAvailable: "Available",
      statusUnavailable: "Unavailable",
      edit: "Edit",
      save: "Save",
      cancel: "Cancel",
      allCats: "All Categories",
      unlimited: "Unlimited",
      updateSuccess: "Updated",
      updateError: "Failed",
      statusUpdated: "Status updated",
      addProduct: "+ Add Product",
      addProductTitle: "Add New Product",
      addProductSuccess: "Product added",
      addProductError: "Failed to add",
      imageUrl: "Image URL",
      description: "Description",
      inventoryHint: "Inventory (leave blank for unlimited)",
    };
---

<AdminLayout lang={uiLang} title={isZh ? "菜品管理 | Sora Ramen" : "Products | Sora Ramen Admin"}>
  <section class="container admin-shell">
    <AdminHeader
      lang={uiLang}
      mode={adminMode}
      pathname={Astro.url.pathname}
      searchParams={Astro.url.searchParams}
      activeNav="products"
      eyebrow="Admin"
      title={copy.title}
      copy={copy.subtitle}
      navLabels={{
        orders: copy.navOrders,
        products: copy.navProducts,
        delivery: isZh ? "配送模式" : "Delivery mode",
        settings: copy.navSettings,
      }}
      langLabels={{ en: copy.langEn, zh: copy.langZh }}
      modeLabels={{ front: copy.modeFront, kitchen: copy.modeKitchen }}
    />

    <div class="product-toolbar card">
      <select id="cat-filter" class="admin-select">
        <option value="all">{copy.allCats}</option>
        {categories.map(c => <option value={c.id}>{c.name}</option>)}
      </select>
      <button type="button" class="primary-button" id="open-add-modal">
        {copy.addProduct}
      </button>
    </div>

    <div class="card table-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>{copy.thName}</th>
            <th>{copy.thCategory}</th>
            <th>{copy.thPrice}</th>
            <th>{copy.thInventory}</th>
            <th>{copy.thStatus}</th>
            <th>{copy.thActions}</th>
          </tr>
        </thead>
        <tbody id="product-tbody">
          {products.map(p => (
            <tr data-id={p.id} data-cat={p.categoryId}>
              <td>
                <div class="prod-cell">
                  <img src={p.imageUrl} alt="" class="prod-thumb" />
                  <div>
                  <strong>{p.name}</strong>
                  <p class="p-desc">{parseDescription(p.description)}</p>
                  </div>
                </div>
              </td>
              <td><span class="cat-tag">{categories.find(c => c.id === p.categoryId)?.name || p.categoryId}</span></td>
              <td>
                <div class="edit-field" data-field="price">
                  <span class="view-val">{format(p.price)}</span>
                  <input type="number" step="0.01" value={p.price} class="edit-input" />
                </div>
              </td>
              <td>
                <div class="edit-field" data-field="inventory">
                  <span class="view-val">{p.inventoryCount ?? copy.unlimited}</span>
                  <input type="number" value={p.inventoryCount ?? ""} placeholder="∞" class="edit-input" />
                </div>
              </td>
              <td>
                <button type="button" class:list={["status-btn", { active: p.isAvailable }]} data-available={p.isAvailable ? "1" : "0"}>
                  {p.isAvailable ? copy.statusAvailable : copy.statusUnavailable}
                </button>
              </td>
              <td>
                <div class="row-actions">
                  <button type="button" class="action-btn edit-btn">{copy.edit}</button>
                  <button type="button" class="action-btn save-btn hidden">{copy.save}</button>
                  <button type="button" class="action-btn cancel-btn hidden">{copy.cancel}</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Add Product Modal -->
    <div id="add-modal" class="admin-overlay hidden">
      <div class="admin-modal card">
        <div class="modal-head">
          <h2>{copy.addProductTitle}</h2>
          <button type="button" class="close-modal" id="close-add-modal">×</button>
        </div>
        <form id="add-product-form" class="admin-form">
          <div class="form-grid">
            <div class="form-field">
              <label>{copy.thName}</label>
              <input type="text" name="name" required placeholder={isZh ? "例如：豚骨拉面" : "Example: Tokyo Tonkotsu"} />
            </div>
            <div class="form-field">
              <label>{copy.thCategory}</label>
              <select name="categoryId" required>
                {categories.map(c => <option value={c.id}>{c.name}</option>)}
              </select>
            </div>
            <div class="form-field">
              <label>{copy.thPrice}</label>
              <input type="number" name="price" step="0.01" required placeholder="0.00" />
            </div>
            <div class="form-field">
              <label>{copy.inventoryHint}</label>
              <input type="number" name="inventoryCount" placeholder="∞" />
            </div>
            <div class="form-field wide">
              <label>{copy.imageUrl}</label>
              <input type="url" name="imageUrl" required placeholder="https://..." />
            </div>
            <div class="form-field wide">
              <label>{copy.description}</label>
              <textarea name="description" rows="2" placeholder={isZh ? "简单描述一下这道菜..." : "Short description..."}></textarea>
            </div>
          </div>
          <div class="form-footer">
            <button type="button" class="ghost-button" id="cancel-add">{copy.cancel}</button>
            <button type="submit" class="primary-button">{isZh ? "确认添加" : "Confirm Add"}</button>
          </div>
        </form>
      </div>
    </div>

    <div id="notice-toast" class="toast hidden"></div>
  </section>
</AdminLayout>

<script is:inline>
  const uiLang = new URLSearchParams(window.location.search).get("ui") === "zh" ? "zh" : "en";
  const tbody = document.getElementById("product-tbody");
  const filter = document.getElementById("cat-filter");
  const toast = document.getElementById("notice-toast");
  const copy = uiLang === "zh"
    ? {
        saved: "更新成功",
        error: "更新失败",
        statusUpdated: "状态已更新",
        productAdded: "菜品已添加",
        addFailed: "添加失败",
        available: "上架中",
        unavailable: "已下架",
        unlimited: "不限",
      }
    : {
        saved: "Updated",
        error: "Failed",
        statusUpdated: "Status updated",
        productAdded: "Product added",
        addFailed: "Failed to add",
        available: "Available",
        unavailable: "Unavailable",
        unlimited: "Unlimited",
      };

  function showToast(msg, type = "success") {
    if (!toast) return;
    toast.textContent = msg;
    toast.className = `toast show ${type}`;
    setTimeout(() => toast.className = "toast hidden", 2000);
  }

  filter?.addEventListener("change", (e) => {
    const cat = e.target.value;
    const rows = tbody?.querySelectorAll("tr");
    rows?.forEach(row => {
      if (cat === "all" || row.dataset.cat === cat) {
        row.style.display = "";
      } else {
        row.style.display = "none";
      }
    });
  });

  tbody?.addEventListener("click", async (e) => {
    const row = e.target.closest("tr");
    if (!row) return;

    if (e.target.classList.contains("edit-btn")) {
      row.classList.add("editing");
      row.dataset.originalPrice = row.querySelector('[data-field="price"] input').value;
      row.dataset.originalInventory = row.querySelector('[data-field="inventory"] input').value;
      row.querySelector(".edit-btn").classList.add("hidden");
      row.querySelector(".save-btn").classList.remove("hidden");
      row.querySelector(".cancel-btn").classList.remove("hidden");
    } else if (e.target.classList.contains("cancel-btn")) {
      row.querySelector('[data-field="price"] input').value = row.dataset.originalPrice || "";
      row.querySelector('[data-field="inventory"] input').value = row.dataset.originalInventory || "";
      row.classList.remove("editing");
      row.querySelector(".edit-btn").classList.remove("hidden");
      row.querySelector(".save-btn").classList.add("hidden");
      row.querySelector(".cancel-btn").classList.add("hidden");
    } else if (e.target.classList.contains("save-btn")) {
      const id = row.dataset.id;
      const price = parseFloat(row.querySelector('[data-field="price"] input').value);
      const inventoryVal = row.querySelector('[data-field="inventory"] input').value;
      const inventoryCount = inventoryVal === "" ? null : parseInt(inventoryVal);
      
      try {
        const res = await fetch(`/api/admin/products/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ price, inventoryCount }),
        });
        if (res.ok) {
          row.querySelector('[data-field="price"] .view-val').textContent = new Intl.NumberFormat(uiLang === "zh" ? "zh-CN" : "en-US", {
            style: "currency",
            currency: "USD",
          }).format(price);
          row.querySelector('[data-field="inventory"] .view-val').textContent = inventoryCount === null ? copy.unlimited : String(inventoryCount);
          row.classList.remove("editing");
          row.querySelector(".edit-btn").classList.remove("hidden");
          row.querySelector(".save-btn").classList.add("hidden");
          row.querySelector(".cancel-btn").classList.add("hidden");
          showToast(copy.saved);
        }
      } catch (err) {
        showToast(copy.error, "error");
      }
    } else if (e.target.classList.contains("status-btn")) {
      const id = row.dataset.id;
      const current = e.target.dataset.available === "1";
      const next = !current;
      
      try {
        const res = await fetch(`/api/admin/products/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ isAvailable: next }),
        });
        if (res.ok) {
          e.target.dataset.available = next ? "1" : "0";
          e.target.classList.toggle("active", next);
          e.target.textContent = next ? copy.available : copy.unavailable;
          showToast(copy.statusUpdated);
        }
      } catch (err) {
        showToast(copy.error, "error");
      }
    }
  });

  const addModal = document.getElementById("add-modal");
  const addForm = document.getElementById("add-product-form");
  const openAddBtn = document.getElementById("open-add-modal");
  const closeAddBtn = document.getElementById("close-add-modal");
  const cancelAddBtn = document.getElementById("cancel-add");

  openAddBtn?.addEventListener("click", () => addModal?.classList.remove("hidden"));
  [closeAddBtn, cancelAddBtn].forEach(b => b?.addEventListener("click", () => addModal?.classList.add("hidden")));

  addForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(addForm);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch("/api/admin/products", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        showToast(copy.productAdded);
        setTimeout(() => window.location.reload(), 800);
      } else {
        const err = await res.json();
        showToast(err.error || copy.addFailed, "error");
      }
    } catch (err) {
      showToast(copy.error, "error");
    }
  });
</script>

<style>
  .admin-shell {
    padding: 32px 0 88px;
  }
  .admin-shell :global(.eyebrow) {
    color: var(--admin-gold);
    font-weight: 800;
  }
  .admin-shell :global(.section-copy) {
    color: var(--admin-muted);
  }
  .product-toolbar {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    padding: 12px;
    margin-bottom: 18px;
    background: #ffffff;
    border: 1px solid rgba(45,108,223,.12);
    box-shadow: 0 12px 34px rgba(15,76,153,.06);
  }
  .table-card {
    background: white;
    overflow: hidden;
    border: 1px solid rgba(45,108,223,.12);
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }
  .admin-table th {
    padding: 16px 24px;
    background: #f8fafc;
    border-bottom: 1px solid #edf2f7;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-text);
  }
  .admin-table td {
    padding: 16px 24px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }
  .prod-cell strong {
    color: var(--admin-text);
  }
  .p-desc {
    color: var(--admin-muted);
    font-size: 0.8125rem;
  }
  .prod-cell {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .prod-thumb {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    object-fit: cover;
  }
  .cat-tag {
    padding: 4px 10px;
    background: #f1f5f9;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .status-btn {
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
  }
  .status-btn.active {
    background: #ecfdf5;
    border-color: #10b981;
    color: #059669;
  }
  .edit-input {
    display: none;
    width: 80px;
    padding: 4px 8px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
  }
  .editing .edit-input {
    display: block;
  }
  .editing .view-val {
    display: none;
  }
  .action-btn {
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(45,108,223,.18);
    border-radius: 999px;
    background: #ffffff;
    color: #174ea6;
    font-weight: 600;
    cursor: pointer;
  }
  .primary-button {
    min-height: 44px;
    padding: 0 18px;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, #174ea6, #2d6cdf);
    color: #ffffff;
    font-weight: 800;
    box-shadow: 0 12px 24px rgba(45,108,223,.22);
  }
  .ghost-button {
    background: white;
    border: 1px solid rgba(45,108,223,.24);
    color: var(--admin-accent) !important;
    font-weight: 700;
  }
  .ghost-button:hover {
    background: rgba(45,108,223,.04);
    border-color: var(--admin-accent);
  }
  .action-btn.save-btn {
    background: #2d6cdf;
    border-color: #2d6cdf;
    color: white;
  }
  .hidden { display: none !important; }
  .row-actions {
    display: flex;
    gap: 8px;
  }
  .toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 12px 24px;
    background: #1e293b;
    color: white;
    border-radius: 12px;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
    z-index: 100;
    transition: all 0.3s;
  }
  .toast.error { background: #ef4444; }
  .admin-select {
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.16);
    background: white;
  }
  .admin-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.4);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  .admin-modal {
    width: min(800px, calc(100% - 32px));
    background: white;
    padding: 0;
    overflow: hidden;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 32px;
    border-bottom: 1px solid #f1f5f9;
  }
  .modal-head h2 { margin: 0; font-size: 1.5rem; }
  .close-modal {
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    color: var(--admin-muted);
  }
  .admin-form { padding: 32px; }
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .form-field.wide { grid-column: 1 / -1; }
  .form-field label {
    display: block;
    margin-bottom: 8px;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--admin-muted);
    text-transform: uppercase;
  }
  .form-field input, .form-field select, .form-field textarea {
    width: 100%;
    padding: 10px 16px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: #f8fafc;
  }
  .form-footer {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid #f1f5f9;
  }
</style>

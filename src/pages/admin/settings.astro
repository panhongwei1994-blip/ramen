---
import AdminHeader from "@/components/admin/AdminHeader.astro";
import AdminLayout from "@/components/layout/AdminLayout.astro";
import { getSettingFromD1, getRuntimeEnv } from "@/lib/orders";
import { getAdminLangFromUrl, getAdminModeFromUrl } from "@/lib/admin-links";

export const prerender = false;

const uiLang = getAdminLangFromUrl(Astro.url);
const isZh = uiLang === "zh";
const adminMode = getAdminModeFromUrl(Astro.url);
const runtimeEnv = getRuntimeEnv(Astro.locals);

const isOpenValue = await getSettingFromD1("is_open", runtimeEnv);
const isOpen = isOpenValue !== "0"; // Default to true if not set

const copy = isZh
  ? {
      title: "店铺设置",
      subtitle: "管理店铺的基础运行状态。",
      statusTitle: "营业状态",
      statusOpen: "正在营业",
      statusClosed: "休息中",
      openDesc: "客户可以正常浏览菜单并下单。",
      closedDesc: "客户将看到休息提示，无法提交新订单。",
      save: "保存更改",
      saving: "保存中...",
      success: "设置已更新",
      error: "更新失败",
      navOrders: "订单队列",
      navProducts: "菜品管理",
      navSettings: "店铺设置",
      langEn: "EN",
      langZh: "中文",
      modeFront: "前台模式",
      modeKitchen: "后厨模式",
    }
  : {
      title: "Shop Settings",
      subtitle: "Manage the basic operational state of your shop.",
      statusTitle: "Business Status",
      statusOpen: "Open for Business",
      statusClosed: "Closed / On Break",
      openDesc: "Customers can browse and place orders normally.",
      closedDesc: "Customers will see a closed notice and cannot place orders.",
      save: "Save Changes",
      saving: "Saving...",
      success: "Settings updated",
      error: "Failed to update",
      navOrders: "Orders",
      navProducts: "Products",
      navSettings: "Settings",
      langEn: "EN",
      langZh: "中文",
      modeFront: "Front mode",
      modeKitchen: "Kitchen mode",
    };
---

<AdminLayout lang={uiLang} title={isZh ? "店铺设置 | Sumi Ramen" : "Settings | Sumi Ramen Admin"}>
  <section class="container admin-shell">
    <AdminHeader
      lang={uiLang}
      mode={adminMode}
      pathname={Astro.url.pathname}
      searchParams={Astro.url.searchParams}
      activeNav="settings"
      eyebrow="Admin"
      title={copy.title}
      copy={copy.subtitle}
      navLabels={{
        orders: copy.navOrders,
        products: copy.navProducts,
        settings: copy.navSettings,
      }}
      langLabels={{ en: copy.langEn, zh: copy.langZh }}
      modeLabels={{ front: copy.modeFront, kitchen: copy.modeKitchen }}
    />

    <div class="card settings-card">
      <div class="setting-row">
        <div class="setting-info">
          <h3>{copy.statusTitle}</h3>
          <p>{isOpen ? copy.openDesc : copy.closedDesc}</p>
        </div>
        <div class="setting-action">
          <button
            type="button"
            class:list={["status-toggle", { active: isOpen }]}
            id="status-toggle"
            data-current={isOpen ? "1" : "0"}
          >
            <div class="toggle-track">
              <div class="toggle-thumb"></div>
            </div>
            <span>{isOpen ? copy.statusOpen : copy.statusClosed}</span>
          </button>
        </div>
      </div>

      <div class="settings-footer">
        <div id="status-message" class="status-msg"></div>
      </div>
    </div>
  </section>
</AdminLayout>

<script is:inline>
  const toggle = document.getElementById("status-toggle");
  const msg = document.getElementById("status-message");
  const settingDesc = document.querySelector(".setting-info p");
  const toggleLabel = toggle?.querySelector("span");
  const isZh = new URLSearchParams(window.location.search).get("ui") === "zh";
  const copy = isZh 
    ? {
        saving: "保存中...",
        success: "设置已更新",
        error: "更新失败",
        open: "正在营业",
        closed: "休息中",
        openDesc: "客户可以正常浏览菜单并下单。",
        closedDesc: "客户将看到休息提示，无法提交新订单。",
      }
    : {
        saving: "Saving...",
        success: "Settings updated",
        error: "Failed to update",
        open: "Open for Business",
        closed: "Closed / On Break",
        openDesc: "Customers can browse and place orders normally.",
        closedDesc: "Customers will see a closed notice and cannot place orders.",
      };

  toggle?.addEventListener("click", async () => {
    const current = toggle.dataset.current;
    const next = current === "1" ? "0" : "1";
    
    if (msg) {
        msg.textContent = copy.saving;
        msg.className = "status-msg info";
    }

    try {
      const res = await fetch("/api/admin/settings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ key: "is_open", value: next }),
      });

      if (res.ok) {
        if (msg) {
            msg.textContent = copy.success;
            msg.className = "status-msg success";
        }
        toggle.dataset.current = next;
        toggle.classList.toggle("active", next === "1");
        if (toggleLabel) {
          toggleLabel.textContent = next === "1" ? copy.open : copy.closed;
        }
        if (settingDesc) {
          settingDesc.textContent = next === "1" ? copy.openDesc : copy.closedDesc;
        }
      } else {
        throw new Error();
      }
    } catch (e) {
      if (msg) {
          msg.textContent = copy.error;
          msg.className = "status-msg error";
      }
    }
  });
</script>

<style>
  .admin-shell {
    padding: 32px 0 88px;
  }
  .admin-shell :global(.eyebrow) {
    color: var(--admin-gold);
    font-weight: 800;
  }
  .admin-shell :global(.section-copy) {
    color: var(--admin-muted);
  }
  .settings-card {
    padding: 32px;
    background: #ffffff;
    border: 1px solid rgba(45,108,223,.12);
  }
  .setting-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .setting-info h3 {
    margin: 0 0 8px;
    font-size: 1.25rem;
    color: var(--admin-text);
  }
  .setting-info p {
    margin: 0;
    color: var(--admin-muted);
    font-weight: 500;
  }
  .status-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.14);
    background: #f1f5f9;
    color: #64748b;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .status-toggle.active {
    background: rgba(45,108,223,.1);
    border-color: #2d6cdf;
    color: #2d6cdf;
  }
  .toggle-track {
    width: 40px;
    height: 20px;
    background: #cbd5e1;
    border-radius: 999px;
    position: relative;
    transition: background 0.2s;
  }
  .active .toggle-track {
    background: #2d6cdf;
  }
  .toggle-thumb {
    width: 16px;
    height: 16px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 2px;
    left: 2px;
    transition: transform 0.2s;
  }
  .active .toggle-thumb {
    transform: translateX(20px);
  }
  .settings-footer {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #f1f5f9;
  }
  .status-msg {
    font-size: 0.875rem;
    font-weight: 500;
  }
  .status-msg.success { color: #10b981; }
  .status-msg.error { color: #ef4444; }
  .status-msg.info { color: #3b82f6; }
</style>

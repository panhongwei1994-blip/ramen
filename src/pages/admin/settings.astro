---
import AdminHeader from "@/components/admin/AdminHeader.astro";
import AdminLayout from "@/components/layout/AdminLayout.astro";
import { getSettingFromD1, getRuntimeEnv } from "@/lib/orders";
import { buildAdminHref, getAdminLangFromUrl, getAdminModeFromUrl } from "@/lib/admin-links";

export const prerender = false;

const uiLang = getAdminLangFromUrl(Astro.url);
const isZh = uiLang === "zh";
const adminMode = getAdminModeFromUrl(Astro.url);
const runtimeEnv = getRuntimeEnv(Astro.locals);
const productsHref = buildAdminHref("/admin/products", Astro.url.searchParams, { lang: uiLang, mode: adminMode, viewAll: false });

const isOpenValue = await getSettingFromD1("is_open", runtimeEnv);
const isOpen = isOpenValue !== "0"; // Default to true if not set

const copy = isZh
  ? {
      title: "店铺设置",
      subtitle: "管理店铺的基础运行状态。",
      statusTitle: "营业状态",
      statusOpen: "正在营业",
      statusClosed: "休息中",
      openDesc: "客户可以正常浏览菜单并下单。",
      closedDesc: "客户将看到休息提示，无法提交新订单。",
      save: "保存更改",
      saving: "保存中...",
      success: "设置已更新",
      error: "更新失败",
      navOrders: "订单队列",
      navSettings: "店铺设置",
      menuManagement: "菜品管理",
      menuManagementDesc: "修改菜单价格、库存和上下架状态。",
      openProducts: "进入菜品管理",
      langEn: "EN",
      langZh: "中文",
      modeFront: "前台模式",
      modeKitchen: "后厨模式",
    }
  : {
      title: "Shop Settings",
      subtitle: "Manage the basic operational state of your shop.",
      statusTitle: "Business Status",
      statusOpen: "Open for Business",
      statusClosed: "Closed / On Break",
      openDesc: "Customers can browse and place orders normally.",
      closedDesc: "Customers will see a closed notice and cannot place orders.",
      save: "Save Changes",
      saving: "Saving...",
      success: "Settings updated",
      error: "Failed to update",
      navOrders: "Orders",
      navSettings: "Settings",
      menuManagement: "Product management",
      menuManagementDesc: "Update menu prices, stock, and availability.",
      openProducts: "Open products",
      langEn: "EN",
      langZh: "中文",
      modeFront: "Front mode",
      modeKitchen: "Kitchen mode",
    };
---

<AdminLayout lang={uiLang} title={isZh ? "店铺设置 | Sora Ramen" : "Settings | Sora Ramen Admin"}>
  <section class="container admin-shell">
    <AdminHeader
      lang={uiLang}
      mode={adminMode}
      pathname={Astro.url.pathname}
      searchParams={Astro.url.searchParams}
      activeNav="settings"
      eyebrow="Admin"
      title={copy.title}
      copy={copy.subtitle}
      navLabels={{
        orders: copy.navOrders,
        delivery: isZh ? "配送模式" : "Delivery mode",
        settings: copy.navSettings,
      }}
      langLabels={{ en: copy.langEn, zh: copy.langZh }}
      modeLabels={{ front: copy.modeFront, kitchen: copy.modeKitchen }}
    />

    <div class="settings-grid">
      <div class="card settings-card">
        <div class="setting-row">
          <div class="setting-info">
            <h3>{copy.statusTitle}</h3>
            <p>{isOpen ? copy.openDesc : copy.closedDesc}</p>
          </div>
          <div class="setting-action">
            <button
              type="button"
              class:list={["status-toggle", { active: isOpen }]}
              id="status-toggle"
              data-current={isOpen ? "1" : "0"}
              role="switch"
              aria-checked={isOpen ? "true" : "false"}
            >
              <div class="toggle-track" aria-hidden="true">
                <span class="toggle-text toggle-text-off">OFF</span>
                <span class="toggle-text toggle-text-on">ON</span>
                <div class="toggle-thumb"></div>
              </div>
              <span>{isOpen ? copy.statusOpen : copy.statusClosed}</span>
            </button>
          </div>
        </div>

        <div class="settings-footer">
          <div id="status-message" class="status-msg"></div>
        </div>
      </div>
      <a class="card settings-card management-card" href={productsHref}>
        <div class="setting-info">
          <h3>{copy.menuManagement}</h3>
          <p>{copy.menuManagementDesc}</p>
        </div>
        <span>{copy.openProducts}</span>
      </a>
    </div>
  </section>
</AdminLayout>

<script is:inline>
  const toggle = document.getElementById("status-toggle");
  const msg = document.getElementById("status-message");
  const settingDesc = document.querySelector(".setting-info p");
  const toggleLabel = toggle?.querySelector("span");
  const isZh = new URLSearchParams(window.location.search).get("ui") === "zh";
  const copy = isZh 
    ? {
        saving: "保存中...",
        success: "设置已更新",
        error: "更新失败",
        open: "正在营业",
        closed: "休息中",
        openDesc: "客户可以正常浏览菜单并下单。",
        closedDesc: "客户将看到休息提示，无法提交新订单。",
      }
    : {
        saving: "Saving...",
        success: "Settings updated",
        error: "Failed to update",
        open: "Open for Business",
        closed: "Closed / On Break",
        openDesc: "Customers can browse and place orders normally.",
        closedDesc: "Customers will see a closed notice and cannot place orders.",
      };

  toggle?.addEventListener("click", async () => {
    const current = toggle.dataset.current;
    const next = current === "1" ? "0" : "1";
    
    if (msg) {
        msg.textContent = copy.saving;
        msg.className = "status-msg info";
    }

    try {
      const res = await fetch("/api/admin/settings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ key: "is_open", value: next }),
      });

      if (res.ok) {
        if (msg) {
            msg.textContent = copy.success;
            msg.className = "status-msg success";
        }
        toggle.dataset.current = next;
        toggle.classList.toggle("active", next === "1");
        toggle.setAttribute("aria-checked", next === "1" ? "true" : "false");
        if (toggleLabel) {
          toggleLabel.textContent = next === "1" ? copy.open : copy.closed;
        }
        if (settingDesc) {
          settingDesc.textContent = next === "1" ? copy.openDesc : copy.closedDesc;
        }
      } else {
        throw new Error();
      }
    } catch (e) {
      if (msg) {
          msg.textContent = copy.error;
          msg.className = "status-msg error";
      }
    }
  });
</script>

<style>
  .admin-shell {
    padding: 32px 0 88px;
  }
  .admin-shell :global(.eyebrow) {
    color: var(--admin-gold);
    font-weight: 800;
  }
  .admin-shell :global(.section-copy) {
    color: var(--admin-muted);
  }
  .settings-card {
    padding: 32px;
    background: #ffffff;
    border: 1px solid rgba(45,108,223,.12);
  }
  .settings-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, .8fr);
    gap: 16px;
  }
  .setting-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .setting-info h3 {
    margin: 0 0 8px;
    font-size: 1.25rem;
    color: var(--admin-text);
  }
  .setting-info p {
    margin: 0;
    color: var(--admin-muted);
    font-weight: 500;
  }
  .management-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    color: inherit;
    text-decoration: none;
    transition: border-color .18s ease, transform .18s ease;
  }
  .management-card:hover {
    border-color: rgba(45,108,223,.28);
    transform: translateY(-1px);
  }
  .management-card span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.16);
    background: rgba(45,108,223,.06);
    color: #174ea6;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .status-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid rgba(45,108,223,.14);
    background: #f1f5f9;
    color: #64748b;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .status-toggle.active {
    background: rgba(45,108,223,.1);
    border-color: #2d6cdf;
    color: #2d6cdf;
  }
  .toggle-track {
    width: 62px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px;
    background: #cbd5e1;
    border-radius: 999px;
    position: relative;
    transition: background 0.2s;
    overflow: hidden;
  }
  .active .toggle-track {
    background: #2d6cdf;
  }
  .toggle-text {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,.9);
    position: relative;
    z-index: 1;
  }
  .toggle-text-off {
    color: #475569;
  }
  .active .toggle-text-off {
    color: rgba(255,255,255,.54);
  }
  .toggle-text-on {
    color: rgba(255,255,255,.54);
  }
  .active .toggle-text-on {
    color: #ffffff;
  }
  .toggle-thumb {
    width: 24px;
    height: 24px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 2px;
    left: 2px;
    transition: transform 0.2s;
    box-shadow: 0 4px 10px rgba(15,23,42,.18);
  }
  .active .toggle-thumb {
    transform: translateX(34px);
  }
  .settings-footer {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #f1f5f9;
  }
  .status-msg {
    font-size: 0.875rem;
    font-weight: 500;
  }
  .status-msg.success { color: #10b981; }
  .status-msg.error { color: #ef4444; }
  .status-msg.info { color: #3b82f6; }
  @media (max-width: 840px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
    .settings-card {
      padding: 22px;
    }
    .setting-row,
    .management-card {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

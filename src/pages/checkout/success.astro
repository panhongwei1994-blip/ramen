---
import { getOrderByOrderNo, getRuntimeEnv } from "@/lib/orders";

export const prerender = false;

const orderNo = Astro.url.searchParams.get("order") ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;
const langQuery = order?.lang === "zh" ? "?ui=zh" : "";
const orderPath = order ? `/orders/${order.orderNo}${langQuery}` : `/`;
---

<!doctype html>
<html lang={order?.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting...</title>
    <style>
      body {
        margin: 0;
        background: #05060A; /* Matches typical dark theme background */
      }
    </style>
  </head>
  <body>
    <script is:inline define:vars={{ orderPath }}>
      try {
        window.localStorage.removeItem("sumi-ramen-cart");
        window.localStorage.setItem("sumi-ramen-order-success-sound", orderPath);
      } catch {
        // Ignore storage access issues.
      }
      window.location.replace(orderPath);
    </script>
  </body>
</html>

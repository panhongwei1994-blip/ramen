---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getOrderByOrderNo, getRuntimeEnv } from "@/lib/orders";

export const prerender = false;

const orderNo = Astro.params.orderNo ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;

if (!order) {
  Astro.response.status = 404;
}

const lang = order?.lang ?? "en";
const format = (value: number) => formatPrice(value, lang);
const statusLabel = (value: string) => value.replaceAll("_", " ");
const shouldReconcile = Boolean(order && order.paymentStatus !== "paid" && order.stripeCheckoutSessionId);
const reconcilePath = order ? `/api/orders/${order.orderNo}/reconcile-payment` : "";
---

<BaseLayout lang={lang}>
  <section
    class="container page-shell"
    data-reconcile-order={shouldReconcile ? "true" : "false"}
    data-reconcile-path={reconcilePath}
  >
    <div class="page-copy">
      <p class="eyebrow">Order Tracking</p>
      <h1 class="section-title">{order ? `Order ${order.orderNo}` : "Order not found"}</h1>
      <p class="section-copy">
        {
          order
            ? "This page reflects the server-side order record. Payment confirmation comes from the Stripe webhook, not the redirect."
            : "We could not find that order number."
        }
      </p>
    </div>

    {order ? (
      <div class="page-grid">
        <section class="card page-card" data-status={order.orderStatus}>
          <div class="status-row">
            <div class="status-indicator">
              {order.orderStatus === 'pending_payment' && '⏳'}
              {order.orderStatus === 'paid_waiting_accept' && '🔔'}
              {order.orderStatus === 'accepted' && '✅'}
              {order.orderStatus === 'cooking' && '👨‍🍳'}
              {order.orderStatus === 'delivering' && '🛵'}
              {order.orderStatus === 'completed' && '📦'}
              {['cancelled', 'refunded'].includes(order.orderStatus) && '❌'}
            </div>
            <div>
              <span class="status-label">Order status</span>
              <strong class="status-value">{statusLabel(order.orderStatus)}</strong>
              <div class:list={["payment-tag", { paid: order.paymentStatus === 'paid' }]}>
                {order.paymentStatus === 'paid' ? '● Paid' : '○ Unpaid'}
              </div>
            </div>
          </div>

          <div class="detail-grid">
            <div>
              <span class="status-label">Customer</span>
              <strong>{order.customerName || "Collected at checkout"}</strong>
              <p>{order.phone || "Pending Stripe confirmation"}</p>
            </div>
            <div>
              <span class="status-label">Fulfillment</span>
              <strong>{order.fulfillment}</strong>
              <p>{order.address || (order.fulfillment === "pickup" ? "Pickup at the store" : "Pending Stripe confirmation")}</p>
            </div>
          </div>

          <div class="line-items">
            {order.items.map((item) => (
              <article class="line-item">
                <img src={item.imageUrl} alt={item.productName} />
                <div>
                  <div class="line-head">
                    <strong>{item.productName}</strong>
                    <strong>{format(item.subtotal)}</strong>
                  </div>
                  <p>{format(item.unitPrice)} each × {item.quantity}</p>
                  {item.addOns.length ? <p>{item.addOns.map((addOn) => addOn.label).join(" · ")}</p> : null}
                  {item.note ? <p>{item.note}</p> : null}
                </div>
              </article>
            ))}
          </div>

          <div class="totals">
            <div><span>Items</span><strong>{format(order.itemsAmount)}</strong></div>
            <div><span>Delivery</span><strong>{format(order.deliveryFee)}</strong></div>
            <div><span>Total</span><strong>{format(order.totalAmount)}</strong></div>
          </div>
        </section>

        <section class="card page-card">
          <h2>Timeline</h2>
          <div class="timeline">
            {order.timeline.map((event) => (
              <article class="timeline-item">
                <strong>{event.message}</strong>
                <span>{new Date(event.createdAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" })}</span>
              </article>
            ))}
          </div>
        </section>
      </div>
    ) : null}
  </section>
</BaseLayout>

<script is:inline>
  const shell = document.querySelector("[data-reconcile-order]");
  const shouldReconcile = shell?.getAttribute("data-reconcile-order") === "true";
  const reconcilePath = shell?.getAttribute("data-reconcile-path");
  const successSoundKey = "sumi-ramen-order-success-sound";

  const playSuccessTone = async () => {
    try {
      const AudioContextCtor = window.AudioContext || window["webkitAudioContext"];
      const context = new AudioContextCtor();
      if (context.state === "suspended") {
        await context.resume();
      }
      const now = context.currentTime;
      [523, 659, 784, 1046].forEach((frequency, index) => {
        const start = now + index * 0.12;
        const stop = start + 0.38;
        const oscillator = context.createOscillator();
        const gain = context.createGain();
        oscillator.type = "sine";
        oscillator.frequency.value = frequency;
        gain.gain.setValueAtTime(0.001, start);
        gain.gain.exponentialRampToValueAtTime(0.12, start + 0.03);
        gain.gain.exponentialRampToValueAtTime(0.001, stop);
        oscillator.connect(gain);
        gain.connect(context.destination);
        oscillator.start(start);
        oscillator.stop(stop);
      });
    } catch {
      // Browsers may block audio after external payment redirects.
    }
  };

  try {
    const flaggedPath = window.localStorage.getItem(successSoundKey);
    if (flaggedPath && window.location.pathname === new URL(flaggedPath, window.location.origin).pathname) {
      window.localStorage.removeItem(successSoundKey);
      window.setTimeout(() => void playSuccessTone(), 350);
    }
  } catch {
    // Ignore storage access issues.
  }

  if (shouldReconcile && reconcilePath) {
    window.setTimeout(() => {
      fetch(reconcilePath, { method: "POST" })
        .then((response) => response.json().catch(() => null))
        .then((data) => {
          if (data?.reconciled) {
            window.location.reload();
          }
        })
        .catch(() => null);
    }, 1200);
  }
</script>

<style>
  .page-shell {
    padding: 140px 0 80px;
  }
  .page-copy {
    max-width: 760px;
    margin-bottom: 28px;
  }
  .page-grid {
    display: grid;
    gap: 20px;
  }
  .page-card {
    padding: 24px;
  }
  .status-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }
  .status-indicator {
    position: relative;
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    border-radius: 20px;
    background: rgba(212, 165, 74, 0.1);
    color: var(--gold-soft);
    font-size: 24px;
    flex-shrink: 0;
  }
  .status-indicator::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 24px;
    border: 2px solid var(--gold-soft);
    opacity: 0;
  }

  /* Animations */
  [data-status="pending_payment"] .status-indicator::before {
    animation: pulse 2s infinite;
    opacity: 0.4;
  }
  [data-status="paid_waiting_accept"] .status-indicator::before {
    animation: ripple 1.5s infinite;
    opacity: 0.6;
  }
  [data-status="cooking"] .status-indicator::after {
    content: "♨️";
    position: absolute;
    top: -10px;
    right: -10px;
    font-size: 20px;
    animation: steam 2s infinite ease-in-out;
  }
  [data-status="delivering"] .status-indicator {
    animation: glide 3s infinite linear;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); opacity: 0.2; }
    50% { transform: scale(1.05); opacity: 0.5; }
    100% { transform: scale(0.95); opacity: 0.2; }
  }
  @keyframes ripple {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.4); opacity: 0; }
  }
  @keyframes steam {
    0% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-8px) scale(1.2); opacity: 0.9; }
    100% { transform: translateY(-16px) scale(1.4); opacity: 0; }
  }
  @keyframes glide {
    0% { transform: translateX(-2px); }
    50% { transform: translateX(2px); }
    100% { transform: translateX(-2px); }
  }

  .status-label {
    display: block;
    margin-bottom: 4px;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .status-value {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    text-transform: capitalize;
  }
  .payment-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    padding: 4px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .payment-tag.paid {
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
    color: #4ade80;
  }

  h2 {
    margin: 0;
  }
  @media (max-width: 720px) {
    .page-shell {
      padding-top: 120px;
    }
    .line-item {
      grid-template-columns: 1fr;
    }
    .line-item img {
      width: 100%;
      max-width: 180px;
    }
  }
</style>

---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import { formatPrice } from "@/data/site";
import { getOrderByOrderNo, getRuntimeEnv } from "@/lib/orders";

export const prerender = false;

const orderNo = Astro.params.orderNo ?? "";
const runtimeEnv = getRuntimeEnv(Astro.locals);
const order = orderNo ? await getOrderByOrderNo(orderNo, runtimeEnv) : null;

if (!order) {
  Astro.response.status = 404;
}

const lang = order?.lang ?? "en";
const format = (value: number) => formatPrice(value, lang);
const statusLabel = (value: string) => value.replaceAll("_", " ");
const shouldReconcile = Boolean(order && order.paymentStatus !== "paid" && order.stripeCheckoutSessionId);
const reconcilePath = order ? `/api/orders/${order.orderNo}/reconcile-payment` : "";
---

<BaseLayout lang={lang}>
  <section
    class="container page-shell"
    data-reconcile-order={shouldReconcile ? "true" : "false"}
    data-reconcile-path={reconcilePath}
  >
    <div class="page-copy">
      <p class="eyebrow">Order Management</p>
      <h1 class="section-title">{order ? `Order #${order.orderNo}` : "Order not found"}</h1>
      <div class="header-badges">
        <span class:list={["badge", { paid: order?.paymentStatus === 'paid' }]}>
          {order?.paymentStatus === 'paid' ? '● Paid' : '○ Unpaid'}
        </span>
        {order && <span class="badge status-badge">{statusLabel(order.orderStatus)}</span>}
      </div>
    </div>

    {order ? (
      <div class="page-grid">
        <section class="card glass-card status-card" data-status={order.orderStatus}>
          <div class="status-steps">
            {[
              { key: 'pending_payment', icon: 'M19 5H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm-5 9l3-3m0 0l-3-3m3 3H9', label: 'Payment' },
              { key: 'paid_waiting_accept', icon: 'M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9m4.3 13a1.94 1.94 0 0 0 3.4 0', label: 'Confim' },
              { key: 'cooking', icon: 'M12 21a9 9 0 0 1 0-18c2 0 3.5.5 5 1.5M12 7l3 3m-3 7l-3-3m10-7v10', label: 'Cooking' },
              { key: 'delivering', icon: 'M5 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm-7-7h4l2 3v3H2v-3l2-3h4', label: 'Delivery' },
              { key: 'completed', icon: 'M21 8l-2-2H5L3 8v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8zM12 13l4 4m0-4l-4 4', label: 'Done' }
            ].map((step, idx, arr) => {
              const states = ['pending_payment', 'paid_waiting_accept', 'accepted', 'cooking', 'delivering', 'completed'];
              const currentIdx = states.indexOf(order.orderStatus);
              const stepIdx = states.indexOf(step.key);
              const isDone = stepIdx < currentIdx || order.orderStatus === 'completed';
              const isActive = order.orderStatus === step.key || (order.orderStatus === 'accepted' && step.key === 'paid_waiting_accept');
              
              return (
                <div class:list={["step", { done: isDone, active: isActive }]}>
                  <div class="step-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      {isDone ? <polyline points="20 6 9 17 4 12" /> : <path d={step.icon} />}
                    </svg>
                  </div>
                  <span class="step-label">{step.label}</span>
                  {idx < arr.length - 1 && <div class="step-line" />}
                </div>
              );
            })}
          </div>
          
          <div class="status-announcement">
            <h3>{statusLabel(order.orderStatus)}</h3>
            <p>{order.paymentStatus === 'paid' ? 'Your order is being handled by our team.' : 'Please complete the payment to start processing.'}</p>
          </div>
        </section>

        <div class="details-layout">
          <section class="card glass-card receipt-section">
            <h2 class="eyebrow">Your Selection</h2>
            <div class="line-items">
              {order.items.map((item) => (
                <article class="line-item">
                  <div class="item-img-wrapper">
                    <img src={item.imageUrl} alt={item.productName} />
                  </div>
                  <div class="item-details">
                    <div class="line-head">
                      <strong>{item.productName}</strong>
                      <span class="price">{format(item.subtotal)}</span>
                    </div>
                    <p class="qty-info">{item.quantity} × {format(item.unitPrice)}</p>
                    {item.addOns.length ? <p class="add-ons">{item.addOns.map((addOn) => addOn.label).join(" · ")}</p> : null}
                  </div>
                </article>
              ))}
            </div>

            <div class="receipt-totals">
              <div class="total-row"><span>Subtotal</span><span>{format(order.itemsAmount)}</span></div>
              <div class="total-row"><span>Delivery</span><span>{format(order.deliveryFee)}</span></div>
              <div class="total-row grand-total"><span>Total Amount</span><span>{format(order.totalAmount)}</span></div>
            </div>
          </section>

          <section class="card glass-card info-section">
            <div class="info-block">
              <h2 class="eyebrow">Customer</h2>
              <strong>{order.customerName || "Collected at checkout"}</strong>
              <p>{order.phone || "Pending confirmation"}</p>
            </div>
            <div class="info-block">
              <h2 class="eyebrow">Delivery Details</h2>
              <strong>{order.fulfillment}</strong>
              <p>{order.address || (order.fulfillment === "pickup" ? "Store Pickup" : "Pending confirmation")}</p>
            </div>
            <div class="info-block">
              <h2 class="eyebrow">Timeline</h2>
              <div class="mini-timeline">
                {order.timeline.slice(0, 3).map((event) => (
                  <div class="mini-event">
                    <span class="event-msg">{event.message}</span>
                    <span class="event-time">{new Date(event.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
                  </div>
                ))}
              </div>
            </div>
          </section>
        </div>
      </div>
    ) : null}
  </section>
</BaseLayout>

<script is:inline>
  const shell = document.querySelector("[data-reconcile-order]");
  const shouldReconcile = shell?.getAttribute("data-reconcile-order") === "true";
  const reconcilePath = shell?.getAttribute("data-reconcile-path");
  const successSoundKey = "sumi-ramen-order-success-sound";

  const playSuccessTone = async () => {
    try {
      const AudioContextCtor = window.AudioContext || window["webkitAudioContext"];
      const context = new AudioContextCtor();
      if (context.state === "suspended") await context.resume();
      const now = context.currentTime;
      [523, 659, 784, 1046].forEach((frequency, index) => {
        const start = now + index * 0.12;
        const stop = start + 0.38;
        const oscillator = context.createOscillator();
        const gain = context.createGain();
        oscillator.type = "sine";
        oscillator.frequency.value = frequency;
        gain.gain.setValueAtTime(0.001, start);
        gain.gain.exponentialRampToValueAtTime(0.12, start + 0.03);
        gain.gain.exponentialRampToValueAtTime(0.001, stop);
        oscillator.connect(gain);
        gain.connect(context.destination);
        oscillator.start(start);
        oscillator.stop(stop);
      });
    } catch {}
  };

  try {
    const flaggedPath = window.localStorage.getItem(successSoundKey);
    if (flaggedPath && window.location.pathname === new URL(flaggedPath, window.location.origin).pathname) {
      window.localStorage.removeItem(successSoundKey);
      window.setTimeout(() => void playSuccessTone(), 350);
    }
  } catch {}

  if (shouldReconcile && reconcilePath) {
    window.setTimeout(() => {
      fetch(reconcilePath, { method: "POST" })
        .then((response) => response.json().catch(() => null))
        .then((data) => { if (data?.reconciled) window.location.reload(); })
        .catch(() => null);
    }, 1200);
  }
</script>

<style>
  .page-shell {
    padding: 140px 0 100px;
  }
  .page-copy {
    margin-bottom: 40px;
  }
  .header-badges {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }
  .badge {
    padding: 6px 14px;
    border-radius: 99px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .badge.paid {
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
    color: #4ade80;
  }
  .status-badge {
    background: rgba(212, 165, 74, 0.1);
    border-color: rgba(212, 165, 74, 0.2);
    color: var(--gold-soft);
  }

  .glass-card {
    background: rgba(20, 15, 13, 0.6);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .status-card {
    padding: 40px 32px;
    margin-bottom: 24px;
    text-align: center;
    border-radius: 32px;
  }
  .status-steps {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    max-width: 800px;
    margin: 0 auto 40px;
    position: relative;
  }
  .step {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    display: grid;
    place-items: center;
    color: rgba(255,255,255,0.2);
    margin-bottom: 12px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .step-icon svg {
    width: 20px;
    height: 20px;
  }
  .step-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
  }
  .step-line {
    position: absolute;
    top: 24px;
    left: calc(50% + 30px);
    right: calc(-50% + 30px);
    height: 2px;
    background: rgba(255,255,255,0.05);
    z-index: -1;
  }

  /* Active/Done States */
  .step.done .step-icon {
    background: rgba(34, 197, 94, 0.15);
    border-color: rgba(34, 197, 94, 0.3);
    color: #4ade80;
  }
  .step.active .step-icon {
    background: var(--gold);
    border-color: var(--gold-soft);
    color: #180d08;
    transform: scale(1.15);
    box-shadow: 0 0 30px rgba(212, 165, 74, 0.4);
    animation: active-pulse 2s infinite;
  }
  .step.active .step-label {
    color: var(--gold-soft);
  }

  @keyframes active-pulse {
    0% { box-shadow: 0 0 20px rgba(212, 165, 74, 0.3); }
    50% { box-shadow: 0 0 40px rgba(212, 165, 74, 0.6); }
    100% { box-shadow: 0 0 20px rgba(212, 165, 74, 0.3); }
  }

  .status-announcement h3 {
    font-size: 1.5rem;
    margin: 0 0 8px;
    color: #fff;
    text-transform: capitalize;
  }
  .status-announcement p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .details-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
  }
  .receipt-section {
    padding: 32px;
    border-radius: 28px;
  }
  .line-items {
    margin: 24px 0;
  }
  .line-item {
    display: flex;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .item-img-wrapper {
    width: 80px;
    height: 80px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .item-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .item-details {
    flex: 1;
  }
  .line-head {
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .line-head strong {
    font-size: 1.05rem;
    color: #fff;
  }
  .qty-info {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .add-ons {
    margin-top: 8px;
    font-size: 0.8rem;
    color: var(--gold-soft);
    opacity: 0.8;
  }

  .receipt-totals {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px dashed rgba(255,255,255,0.1);
    display: grid;
    gap: 12px;
  }
  .total-row {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .grand-total {
    margin-top: 8px;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--gold-soft);
  }

  .info-section {
    padding: 32px;
    border-radius: 28px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .info-block strong {
    display: block;
    margin: 8px 0 4px;
    color: #fff;
  }
  .info-block p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .mini-timeline {
    margin-top: 16px;
    display: grid;
    gap: 16px;
  }
  .mini-event {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 14px;
    border-left: 2px solid rgba(212, 165, 74, 0.2);
  }
  .event-msg {
    font-size: 0.85rem;
    color: var(--text);
  }
  .event-time {
    font-size: 0.75rem;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .details-layout {
      grid-template-columns: 1fr;
    }
    .info-section {
      order: -1;
    }
  }
  @media (max-width: 600px) {
    .status-card {
      padding: 32px 16px;
    }
    .status-steps {
      gap: 4px;
    }
    .step-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
    }
    .step-line {
      left: calc(50% + 24px);
      right: calc(-50% + 24px);
    }
    .step-label {
      font-size: 8px;
    }
  }
</style>
  @media (max-width: 720px) {
    .page-shell {
      padding-top: 120px;
    }
    .line-item {
      grid-template-columns: 1fr;
    }
    .line-item img {
      width: 100%;
      max-width: 180px;
    }
  }
</style>
